{%- liquid
  assign section_id = 'password-' | append: section.id
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign image = section.settings.background_image
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
  assign show_newsletter = section.settings.show_newsletter
  assign newsletter_heading = section.settings.newsletter_heading
  assign newsletter_placeholder = section.settings.newsletter_placeholder
  assign newsletter_submit_label = section.settings.newsletter_submit_label
  assign password_label = 'password.password' | t
  assign password_submit = 'password.enter' | t
-%}

<section
  id="{{ section_id }}"
  class="glaze-password full-width"
  style="
    --bg: {{ bg_color }};
    --fg: {{ text_color }};
  "
>
  {%- if image != blank -%}
    <div class="glaze-password__media" aria-hidden="true">
      {{ image | image_url: width: 2400 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw',
          widths: '600, 900, 1200, 1600, 2000, 2400',
          alt: ''
      }}
    </div>
  {%- endif -%}

  <div class="glaze-password__inner">
    {%- if eyebrow != blank -%}
      <p class="glaze-password__eyebrow">{{ eyebrow | escape }}</p>
    {%- endif -%}

    {%- if shop.logo != blank -%}
      <div class="glaze-password__logo">
        {{ shop.logo | image_url: width: 320 | image_tag:
            loading: 'eager',
            sizes: '160px',
            widths: '160, 240, 320',
            alt: shop.name
        }}
      </div>
    {%- else -%}
      <p class="glaze-password__shopname">{{ shop.name }}</p>
    {%- endif -%}

    <h1 class="glaze-password__heading">{{ heading | escape }}</h1>

    {%- if subheading != blank -%}
      <p class="glaze-password__subheading">{{ subheading | escape }}</p>
    {%- endif -%}

    {%- if shop.password_message != blank -%}
      <div class="glaze-password__message">{{ shop.password_message }}</div>
    {%- endif -%}

    <details class="glaze-password__details">
      <summary class="glaze-btn glaze-btn--solid">{{ password_submit }}</summary>

      {%- form 'storefront_password', class: 'glaze-password__form' -%}
        {%- if form.errors -%}
          <p class="glaze-password__error" role="alert">{{ form.errors | default_errors }}</p>
        {%- endif -%}

        <label for="{{ section_id }}-password" class="visually-hidden">{{ password_label }}</label>
        <input
          type="password"
          name="password"
          id="{{ section_id }}-password"
          placeholder="{{ password_label }}"
          autocomplete="current-password"
          required
          aria-required="true"
        >
        <button type="submit" class="glaze-btn glaze-btn--solid">{{ password_submit }}</button>
      {%- endform -%}
    </details>

    {%- if show_newsletter -%}
      <div class="glaze-password__newsletter">
        {%- if newsletter_heading != blank -%}
          <h2 class="glaze-password__newsletter-heading">{{ newsletter_heading | escape }}</h2>
        {%- endif -%}
        {%- form 'customer', class: 'glaze-password__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          {%- if form.posted_successfully? -%}
            <p class="glaze-password__newsletter-success" role="status">{{ 'password.newsletter_success' | t }}</p>
          {%- endif -%}
          {%- if form.errors -%}
            <p class="glaze-password__newsletter-error" role="alert">{{ form.errors | default_errors }}</p>
          {%- endif -%}
          <label for="{{ section_id }}-newsletter-email" class="visually-hidden">{{ 'password.newsletter_email' | t }}</label>
          <input
            type="email"
            id="{{ section_id }}-newsletter-email"
            name="contact[email]"
            placeholder="{{ newsletter_placeholder | escape }}"
            autocomplete="email"
            required
            aria-required="true"
          >
          <button type="submit" class="glaze-btn glaze-btn--solid">{{ newsletter_submit_label | escape }}</button>
        {%- endform -%}
      </div>
    {%- endif -%}

    {%- if shop.password_message contains 'social' or section.settings.show_social -%}
      <ul class="glaze-password__social" aria-label="{{ 'password.social_aria' | t }}">
        {%- if section.settings.social_instagram != blank -%}
          <li><a href="{{ section.settings.social_instagram }}" rel="noopener" target="_blank">Instagram</a></li>
        {%- endif -%}
        {%- if section.settings.social_facebook != blank -%}
          <li><a href="{{ section.settings.social_facebook }}" rel="noopener" target="_blank">Facebook</a></li>
        {%- endif -%}
        {%- if section.settings.social_tiktok != blank -%}
          <li><a href="{{ section.settings.social_tiktok }}" rel="noopener" target="_blank">TikTok</a></li>
        {%- endif -%}
      </ul>
    {%- endif -%}

    <p class="glaze-password__powered">{{ powered_by_link }}</p>
  </div>
</section>

{% stylesheet %}
  .glaze-password {
    background: var(--bg, var(--g-cream));
    color: var(--fg, var(--g-ink));
    font-family: var(--g-body-font);
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: 60px 24px;
    position: relative;
    text-align: center;
    isolation: isolate;
  }
  .glaze-password__media {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }
  .glaze-password__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.7;
  }
  .glaze-password__inner {
    max-width: 520px;
    width: 100%;
    display: grid;
    gap: 18px;
    justify-items: center;
  }
  .glaze-password__eyebrow {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0;
    color: var(--fg);
    opacity: 0.65;
  }
  .glaze-password__logo img {
    max-width: 160px;
    height: auto;
  }
  .glaze-password__shopname {
    font-family: var(--g-display-font);
    font-size: 24px;
    font-weight: 700;
    margin: 0;
  }
  .glaze-password__heading {
    font-family: var(--g-display-font);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 600;
    line-height: 1.1;
    margin: 0;
  }
  .glaze-password__subheading {
    font-size: 16px;
    line-height: 1.55;
    margin: 0;
    opacity: 0.78;
    max-width: 36ch;
  }
  .glaze-password__message {
    font-size: 14px;
    line-height: 1.55;
    background: rgba(255,255,255,0.6);
    padding: 12px 16px;
    border-radius: var(--g-radius-md);
  }
  .glaze-password__details {
    width: 100%;
    display: grid;
    justify-items: center;
    gap: 12px;
  }
  .glaze-password__details > summary {
    list-style: none;
    cursor: pointer;
  }
  .glaze-password__details > summary::-webkit-details-marker {
    display: none;
  }
  .glaze-password__details[open] > summary {
    display: none;
  }
  .glaze-password__form {
    display: grid;
    gap: 8px;
    width: 100%;
    max-width: 320px;
  }
  .glaze-password__form input,
  .glaze-password__newsletter-form input {
    font: inherit;
    background: var(--g-card-bg);
    color: var(--g-ink);
    border: 1px solid var(--g-line);
    border-radius: var(--g-radius-md);
    padding: 12px 16px;
    min-height: var(--g-touch);
    text-align: center;
    width: 100%;
  }
  .glaze-password__form input:focus,
  .glaze-password__newsletter-form input:focus {
    outline: 2px solid var(--g-rose);
    outline-offset: 2px;
  }
  .glaze-password__newsletter {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--g-line);
    width: 100%;
    display: grid;
    gap: 12px;
  }
  .glaze-password__newsletter-heading {
    font-family: var(--g-display-font);
    font-size: 18px;
    font-weight: 600;
    margin: 0;
  }
  .glaze-password__newsletter-form {
    display: grid;
    gap: 8px;
    max-width: 320px;
    margin: 0 auto;
    width: 100%;
  }
  .glaze-password__newsletter-success {
    color: var(--g-success-fg);
    background: var(--g-success-bg);
    border-radius: var(--g-radius-md);
    padding: 8px 12px;
    margin: 0;
  }
  .glaze-password__newsletter-error,
  .glaze-password__error {
    color: var(--g-error-fg);
    background: var(--g-error-bg);
    border-radius: var(--g-radius-md);
    padding: 8px 12px;
    margin: 0;
  }
  .glaze-password__social {
    display: flex;
    gap: 16px;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 12px 0 0;
  }
  .glaze-password__social a {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 4px;
    min-height: var(--g-touch);
    display: inline-flex;
    align-items: center;
  }
  .glaze-password__powered {
    margin: 16px 0 0;
    font-size: 12px;
    opacity: 0.65;
  }
  /* .glaze-btn family + .visually-hidden live in assets/base.css */
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.password",
  "tag": "section",
  "class": "section-password",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.password.eyebrow",
      "default": "Opening soon"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.password.heading",
      "default": "Something exciting is coming"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.password.subheading",
      "default": "Be the first to know when we launch."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.password.background_image"
    },
    {
      "type": "header",
      "content": "t:sections.password.newsletter_header"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "t:sections.password.show_newsletter",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "t:sections.password.newsletter_heading",
      "default": "Get on the list"
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "t:sections.password.newsletter_placeholder",
      "default": "Email address"
    },
    {
      "type": "text",
      "id": "newsletter_submit_label",
      "label": "t:sections.password.newsletter_submit_label",
      "default": "Notify me"
    },
    {
      "type": "header",
      "content": "t:sections.password.social_header"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "t:sections.password.show_social",
      "default": true
    },
    { "type": "url", "id": "social_instagram", "label": "t:sections.password.social_instagram" },
    { "type": "url", "id": "social_facebook", "label": "t:sections.password.social_facebook" },
    { "type": "url", "id": "social_tiktok", "label": "t:sections.password.social_tiktok" },
    {
      "type": "header",
      "content": "t:sections.password.colors_header"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:sections.password.bg_color",
      "default": "#fbe9e8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.password.text_color",
      "default": "#1a1a1a"
    }
  ]
}
{% endschema %}
