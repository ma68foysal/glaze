{%- liquid
  assign section_id = 'sleek-cl-' | append: section.id
  assign per_view = section.settings.cards_per_view
-%}

<style>
  /* ============================================================
     Collection List Sleek — scoped styles (scl prefix)
     ============================================================ */

  #{{ section_id }} {
    --scl-bg: {{ section.settings.bg_color }};
    --scl-fg: {{ section.settings.text_color }};
    --scl-radius: {{ section.settings.card_radius }}px;

    --scl-eyebrow-c: {{ section.settings.eyebrow_color }};
    --scl-eyebrow-s: {{ section.settings.eyebrow_size }}px;
    --scl-title-c: {{ section.settings.title_color }};
    --scl-title-s: {{ section.settings.title_size }}px;
    --scl-title-w: {{ section.settings.title_weight }};
    --scl-desc-c: {{ section.settings.desc_color }};
    --scl-desc-s: {{ section.settings.desc_size }}px;

    --scl-card-bg: {{ section.settings.card_bg }};
    --scl-card-title-c: {{ section.settings.card_title_color }};
    --scl-card-title-s: {{ section.settings.card_title_size }}px;
    --scl-card-count-c: {{ section.settings.card_count_color }};
    --scl-card-count-s: {{ section.settings.card_count_size }}px;

    --scl-btn-bg: {{ section.settings.btn_bg }};
    --scl-btn-fg: {{ section.settings.btn_fg }};
    --scl-btn-hover-bg: {{ section.settings.btn_hover_bg }};
    --scl-btn-hover-fg: {{ section.settings.btn_hover_fg }};

    --scl-nav-bg: {{ section.settings.nav_bg }};
    --scl-nav-fg: {{ section.settings.nav_fg }};
    --scl-nav-hover-bg: {{ section.settings.nav_hover_bg }};
    --scl-nav-hover-fg: {{ section.settings.nav_hover_fg }};

    --scl-gap: {{ section.settings.card_gap }}px;
    --scl-per-view: {{ per_view }};
    --scl-pad-top: {{ section.settings.padding_top }}px;
    --scl-pad-bottom: {{ section.settings.padding_bottom }}px;

    display: block;
    background: var(--scl-bg);
    color: var(--scl-fg);
    padding: var(--scl-pad-top) 0 var(--scl-pad-bottom);
    overflow: hidden;
  }

  #{{ section_id }} *,
  #{{ section_id }} *::before,
  #{{ section_id }} *::after { box-sizing: border-box; }

  .scl-wrap {
    padding: 0 0 0 40px;
    display: grid;
    grid-template-columns: minmax(260px, 380px) 1fr;
    gap: 40px;
    align-items: start;
  }

  /* -------- Info column (left) -------- */
  .scl-info {
    padding: 10px 0;
    display: flex;
    flex-direction: column;
  }

  .scl-eyebrow {
    margin: 0 0 20px;
    color: var(--scl-eyebrow-c);
    font-size: var(--scl-eyebrow-s);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .scl-title {
    margin: 0 0 20px;
    color: var(--scl-title-c);
    font-size: var(--scl-title-s);
    font-weight: var(--scl-title-w);
    line-height: 1.1;
    letter-spacing: -0.01em;
  }

  .scl-desc {
    margin: 0 0 36px;
    color: var(--scl-desc-c);
    font-size: var(--scl-desc-s);
    line-height: 1.55;
    max-width: 34ch;
  }

  .scl-nav {
    display: inline-flex;
    gap: 12px;
    margin-top: auto;
  }

  .scl-nav-btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.15);
    background: var(--scl-nav-bg);
    color: var(--scl-nav-fg);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
  }

  .scl-nav-btn:hover:not([disabled]) {
    background: var(--scl-nav-hover-bg);
    color: var(--scl-nav-hover-fg);
    border-color: var(--scl-nav-hover-bg);
    transform: scale(1.05);
  }

  .scl-nav-btn[disabled] { opacity: 0.35; cursor: default; }
  .scl-nav-btn svg { width: 18px; height: 18px; }

  /* -------- Slider (right) -------- */
  .scl-slider {
    position: relative;
    width: 100%;
    overflow: visible;
  }

  .scl-viewport {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .scl-track {
    display: flex;
    gap: var(--scl-gap);
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  /* Card width = (100% - total gaps in view) / per-view */
  .scl-card {
    flex: 0 0 calc((100% - (var(--scl-per-view) - 1) * var(--scl-gap)) / var(--scl-per-view));
    background: var(--scl-card-bg);
    border-radius: var(--scl-radius);
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: transform 0.35s ease;
  }

  .scl-card-media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #efefef;
  }

  .scl-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .scl-card:hover .scl-card-media img { transform: scale(1.04); }

  .scl-card-body {
    padding: 18px 22px 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
  }

  .scl-card-info { min-width: 0; }

  .scl-card-title {
    margin: 0 0 4px;
    color: var(--scl-card-title-c);
    font-size: var(--scl-card-title-s);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .scl-card-count {
    margin: 0;
    color: var(--scl-card-count-c);
    font-size: var(--scl-card-count-s);
  }

  /* Arrow button with glass sweep (same pattern as featured product CTA) */
  .scl-card-link {
    position: relative;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 0;
    background: var(--scl-btn-bg);
    color: var(--scl-btn-fg);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    overflow: hidden;
    flex-shrink: 0;
    transition: background 0.4s ease, color 0.4s ease, transform 0.3s ease;
    text-decoration: none;
  }

  .scl-card-link:hover {
    background: var(--scl-btn-hover-bg);
    color: var(--scl-btn-hover-fg);
  }

  .scl-card-link::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 80%;
    height: 100%;
    background: linear-gradient(120deg,
      transparent 0%,
      rgba(255, 255, 255, 0) 30%,
      rgba(255, 255, 255, 0.55) 50%,
      rgba(255, 255, 255, 0) 70%,
      transparent 100%);
    pointer-events: none;
    transition: left 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .scl-card-link:hover::before { left: 140%; }
  .scl-card-link:not(:hover)::before { transition: left 0.6s cubic-bezier(0.4, 0, 0.2, 1); }

  .scl-card-link svg {
    width: 16px;
    height: 16px;
    position: relative;
    z-index: 1;
  }

  /* -------- Responsive -------- */
  @media screen and (max-width: 1200px) {
    #{{ section_id }} { --scl-per-view: {% if per_view > 2 %}2{% else %}{{ per_view }}{% endif %}; }
  }

  @media screen and (max-width: 900px) {
    .scl-wrap {
      grid-template-columns: 1fr;
      gap: 28px;
      padding: 0 0 0 24px;
    }
    .scl-info { padding: 0 24px 0 0; }
    .scl-desc { max-width: 100%; }
    .scl-nav { margin-top: 4px; }
  }

  @media screen and (max-width: 749px) {
    #{{ section_id }} { --scl-per-view: 1.4; }
    .scl-wrap { padding: 0 0 0 16px; }
    .scl-nav { display: none; }
    .scl-card-media { aspect-ratio: 1 / 1; }
    .scl-card-body { padding: 12px 14px 14px; }
    .scl-card-title { font-size: 15px; }
    .scl-card-count { font-size: 12px; }
    .scl-card-link { width: 34px; height: 34px; }
    .scl-card-link svg { width: 12px; height: 12px; }
    .scl-eyebrow { margin-bottom: 10px; }
    .scl-title { margin-bottom: 12px; font-size: 30px; }
    .scl-desc { margin-bottom: 18px; font-size: 14px; }
  }
</style>

<div id="{{ section_id }}" class="sleek-cl" data-sleek-cl>
  <div class="scl-wrap">

    <div class="scl-info">
      {%- if section.settings.eyebrow != blank -%}
        <p class="scl-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="scl-title">{{ section.settings.title }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="scl-desc">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 1 -%}
        <div class="scl-nav">
          <button type="button" class="scl-nav-btn" data-scl-prev aria-label="Previous">
            <svg viewBox="0 0 18 18" fill="none">
              <path d="M11 3L5 9l6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button type="button" class="scl-nav-btn" data-scl-next aria-label="Next">
            <svg viewBox="0 0 18 18" fill="none">
              <path d="M7 3l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      {%- endif -%}
    </div>

    <div class="scl-slider" data-scl-slider>
      <div class="scl-viewport">
        <div class="scl-track" data-scl-track>
          {%- for block in section.blocks -%}
            {%- assign collection = block.settings.collection -%}
            {%- assign card_image = block.settings.image -%}
            {%- if card_image == blank and collection != blank -%}
              {%- assign card_image = collection.image | default: collection.featured_image -%}
              {%- if card_image == blank and collection.products.size > 0 -%}
                {%- assign card_image = collection.products.first.featured_image -%}
              {%- endif -%}
            {%- endif -%}

            {%- assign card_title = block.settings.title -%}
            {%- if card_title == blank and collection != blank -%}
              {%- assign card_title = collection.title -%}
            {%- endif -%}

            {%- assign card_url = block.settings.link -%}
            {%- if card_url == blank and collection != blank -%}
              {%- assign card_url = collection.url -%}
            {%- endif -%}

            {%- assign card_count = block.settings.count_text -%}
            {%- if card_count == blank and collection != blank -%}
              {%- assign card_count = collection.products_count | append: ' items' -%}
            {%- endif -%}

            <a
              href="{{ card_url | default: '#' }}"
              class="scl-card"
              {{ block.shopify_attributes }}
            >
              <div class="scl-card-media">
                {%- if card_image != blank -%}
                  {{ card_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: card_title, widths: '300,400,600,800,1000' }}
                {%- endif -%}
              </div>
              <div class="scl-card-body">
                <div class="scl-card-info">
                  <p class="scl-card-title">{{ card_title }}</p>
                  {%- if card_count != blank -%}
                    <p class="scl-card-count">{{ card_count }}</p>
                  {%- endif -%}
                </div>
                <span class="scl-card-link" aria-hidden="true">
                  <svg viewBox="0 0 16 16" fill="none">
                    <path d="M3 13L13 3M13 3H6M13 3v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
            </a>
          {%- endfor -%}
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('{{ section_id }}');
    if (!root) return;

    var track = root.querySelector('[data-scl-track]');
    var cards = track ? track.querySelectorAll('.scl-card') : [];
    var prev = root.querySelector('[data-scl-prev]');
    var next = root.querySelector('[data-scl-next]');
    var total = cards.length;
    if (!track || total === 0) return;

    var current = 0;

    function getPerView() {
      var v = parseFloat(getComputedStyle(root).getPropertyValue('--scl-per-view')) || 1;
      return v;
    }

    function computeStep() {
      if (!cards.length) return 0;
      var rect = cards[0].getBoundingClientRect();
      var gap = parseFloat(getComputedStyle(track).columnGap || getComputedStyle(track).gap || '0') || 0;
      return rect.width + gap;
    }

    function maxIndex() {
      return Math.max(0, total - Math.floor(getPerView()));
    }

    function applyTransform(animate) {
      var step = computeStep();
      if (animate === false) track.style.transition = 'none';
      track.style.transform = 'translateX(' + (-current * step) + 'px)';
      if (animate === false) {
        void track.offsetWidth;
        track.style.transition = '';
      }
    }

    function updateNav() {
      if (prev) prev.disabled = current <= 0;
      if (next) next.disabled = current >= maxIndex();
    }

    function goTo(idx) {
      var mx = maxIndex();
      current = Math.max(0, Math.min(mx, idx));
      applyTransform(true);
      updateNav();
    }

    if (prev) prev.addEventListener('click', function () { goTo(current - 1); });
    if (next) next.addEventListener('click', function () { goTo(current + 1); });

    // Touch swipe
    var startX = 0, dx = 0, dragging = false;
    track.addEventListener('touchstart', function (e) {
      if (!e.touches || !e.touches[0]) return;
      startX = e.touches[0].clientX;
      dragging = true;
    }, { passive: true });
    track.addEventListener('touchmove', function (e) {
      if (!dragging || !e.touches || !e.touches[0]) return;
      dx = e.touches[0].clientX - startX;
    }, { passive: true });
    track.addEventListener('touchend', function () {
      if (!dragging) return;
      dragging = false;
      if (Math.abs(dx) > 40) { dx < 0 ? goTo(current + 1) : goTo(current - 1); }
      dx = 0;
    });

    // Resize
    var resizeTimer = null;
    window.addEventListener('resize', function () {
      if (resizeTimer) clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        var mx = maxIndex();
        if (current > mx) current = mx;
        applyTransform(false);
        updateNav();
      }, 80);
    });

    // Kickoff
    applyTransform(false);
    updateNav();
  })();
</script>

{% schema %}
{
  "name": "Collection list",
  "class": "section-collection-list-sleek",
  "tag": "section",
  "max_blocks": 16,
  "settings": [
    {
      "type": "header",
      "content": "Content (left side)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Care For Your Skin"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Natural self care products"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We create safe products that really work and are designed to make you feel good"
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "range",
      "id": "cards_per_view",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Cards per view (desktop)",
      "default": 3
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Gap between cards",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Card radius",
      "default": 14
    },
    {
      "type": "header",
      "content": "Section colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#f2ebe5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Default text",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Eyebrow"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 22,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Size",
      "default": 44
    },
    {
      "type": "range",
      "id": "title_weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "label": "Weight",
      "default": 600
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Color",
      "default": "#3a3a3a"
    },
    {
      "type": "range",
      "id": "desc_size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Size",
      "default": 15
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Title color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "card_title_size",
      "min": 14,
      "max": 26,
      "step": 1,
      "unit": "px",
      "label": "Title size",
      "default": 18
    },
    {
      "type": "color",
      "id": "card_count_color",
      "label": "Count/subtitle color",
      "default": "#777777"
    },
    {
      "type": "range",
      "id": "card_count_size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Count size",
      "default": 13
    },
    {
      "type": "header",
      "content": "Card arrow button"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Background",
      "default": "#f2f2f2"
    },
    {
      "type": "color",
      "id": "btn_fg",
      "label": "Icon color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "btn_hover_bg",
      "label": "Hover background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "btn_hover_fg",
      "label": "Hover icon color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Nav buttons (prev / next)"
    },
    {
      "type": "color",
      "id": "nav_bg",
      "label": "Background",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "nav_fg",
      "label": "Icon color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "nav_hover_bg",
      "label": "Hover background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "nav_hover_fg",
      "label": "Hover icon color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image override",
          "info": "Optional. Falls back to collection image, then first product image."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title override"
        },
        {
          "type": "text",
          "id": "count_text",
          "label": "Subtitle override",
          "info": "Defaults to \"{count} items\"."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link override"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
