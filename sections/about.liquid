{%- liquid
  assign section_id = 'glaze-ab-' | append: section.id
  assign cols = section.settings.columns_desktop
  if cols > 2
    assign cols_tablet = 2
  else
    assign cols_tablet = cols
  endif
-%}

{%- comment -%}
  Per-instance CSS variables. Structural styles live in assets/base.css
  under "S4. About".
{%- endcomment -%}
<style>
  #{{ section_id }} {
    --ab-bg: {{ section.settings.bg_color }};
    --ab-title-c: {{ section.settings.title_color }};
    --ab-title-s: {{ section.settings.title_size }}px;
    --ab-title-w: {{ section.settings.title_weight }};
    --ab-link-c: {{ section.settings.link_color }};
    --ab-link-s: {{ section.settings.link_size }}px;
    --ab-card-title-c: {{ section.settings.card_title_color }};
    --ab-card-title-s: {{ section.settings.card_title_size }}px;
    --ab-card-title-w: {{ section.settings.card_title_weight }};
    --ab-btn-bg: {{ section.settings.btn_bg }};
    --ab-btn-fg: {{ section.settings.btn_fg }};
    --ab-btn-hover-bg: {{ section.settings.btn_hover_bg }};
    --ab-btn-hover-fg: {{ section.settings.btn_hover_fg }};
    --ab-card-radius: {{ section.settings.card_radius }}px;
    --ab-gap: {{ section.settings.card_gap }}px;
    --ab-cols: {{ cols }};
    --ab-cols-tablet: {{ cols_tablet }};
    --ab-pad-top: {{ section.settings.padding_top }}px;
    --ab-pad-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>

<div id="{{ section_id }}" class="glaze-ab">
  <div class="ab-wrap">

    {%- if section.settings.title != blank or section.settings.link_label != blank -%}
      <div class="ab-head">
        {%- if section.settings.title != blank -%}
          <h2 class="ab-title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.link_label != blank -%}
          <a href="{{ section.settings.link_url | default: '#' }}" class="ab-link">{{ section.settings.link_label }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="ab-grid">
      {%- for block in section.blocks -%}
        {%- capture card_inner -%}
          <div class="ab-card-media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.title, widths: '300,500,700,800' }}
            {%- endif -%}
          </div>
          <div class="ab-card-content">
            {%- if block.settings.title != blank -%}
              <h3 class="ab-card-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.btn_label != blank -%}
              <span class="ab-card-btn">{{ block.settings.btn_label }}</span>
            {%- endif -%}
          </div>
        {%- endcapture -%}

        {%- if block.settings.link != blank -%}
          <a
            href="{{ block.settings.link }}"
            class="ab-card"
            style="background: {{ block.settings.bg_color }};"
            {{ block.shopify_attributes }}
          >{{ card_inner }}</a>
        {%- else -%}
          <div
            class="ab-card"
            style="background: {{ block.settings.bg_color }};"
            {{ block.shopify_attributes }}
          >{{ card_inner }}</div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "About",
  "class": "section-about-glaze",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Spring styles to wear together or apart, whatever the weather."
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 34
    },
    {
      "type": "range",
      "id": "title_weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "label": "Title weight",
      "default": 600
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "About Us"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "link_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Link size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns (desktop)",
      "default": 3
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Gap between cards",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Card radius",
      "default": 12
    },
    {
      "type": "header",
      "content": "Card title"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "card_title_size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Size",
      "default": 22
    },
    {
      "type": "range",
      "id": "card_title_weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "label": "Weight",
      "default": 600
    },
    {
      "type": "header",
      "content": "Card button"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "btn_fg",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_hover_bg",
      "label": "Hover background",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "btn_hover_fg",
      "label": "Hover text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Card background",
          "default": "#efe9de"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "News, tips, reviews"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button label",
          "default": "View Our Blog"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About",
      "blocks": [
        { "type": "card", "settings": { "title": "News, tips, reviews", "btn_label": "View Our Blog", "bg_color": "#ebebeb" } },
        { "type": "card", "settings": { "title": "Stores near you", "btn_label": "Find A Store", "bg_color": "#c9b49a" } },
        { "type": "card", "settings": { "title": "On the gram", "btn_label": "@Glossy_store", "bg_color": "#e9cbcb" } }
      ]
    }
  ]
}
{% endschema %}
