{%- liquid
  assign sid = 'Quote-' | append: section.id
-%}

<style>
  #{{ sid }} {
    --c-bg: {{ section.settings.bg_color }};
    --c-fg: {{ section.settings.text_color }};
    --c-muted: {{ section.settings.muted_color }};
    --c-accent: {{ section.settings.accent_color }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --max-w: {{ section.settings.max_width }}px;
    --side-pad: {{ section.settings.side_padding }}px;
    --font-d: {{ section.settings.font_display | default: "var(--g-display-font, sans-serif)" }};
    --font-b: {{ section.settings.font_body | default: "var(--g-body-font, sans-serif)" }};
    background: var(--c-bg);
    color: var(--c-fg);
    font-family: var(--font-b);
    padding: var(--pt) 0 var(--pb);
  }
  #{{ sid }} *, #{{ sid }} *::before, #{{ sid }} *::after { box-sizing: border-box; }
  @media (max-width: 749px) { #{{ sid }} { --side-pad: 16px; --pt: {{ section.settings.padding_top | times: 0.55 | round }}px; --pb: {{ section.settings.padding_bottom | times: 0.55 | round }}px; } }

  #{{ sid }} .qm__container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--side-pad);
    text-align: center;
  }
  #{{ sid }} .qm__quote {
    font-family: var(--font-d);
    font-size: clamp({{ section.settings.quote_size_min }}px, {{ section.settings.quote_size_vw }}vw, {{ section.settings.quote_size_max }}px);
    font-weight: 600;
    color: {{ section.settings.quote_color }};
    line-height: 1.35;
    margin: 0 auto;
    max-width: 32ch;
    letter-spacing: -0.01em;
  }
  #{{ sid }} .qm__quote::before { content: '“'; color: var(--c-accent); margin-right: 4px; }
  #{{ sid }} .qm__quote::after  { content: '”'; color: var(--c-accent); margin-left: 4px; }
  #{{ sid }} .qm__cite {
    margin-top: 18px;
    display: inline-flex; align-items: center; gap: 12px;
    font-size: 13px;
    color: var(--c-muted);
  }
  #{{ sid }} .qm__avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--c-accent);
    color: {{ section.settings.avatar_text_color }};
    display: inline-flex; align-items: center; justify-content: center;
    font-family: var(--font-d);
    font-weight: 700;
    font-size: 13px;
  }
  #{{ sid }} .qm__avatar img { width: 100%; height: 100%; object-fit: cover; }
  #{{ sid }} .qm__name { font-weight: 700; color: {{ section.settings.quote_color }}; }
</style>

<section id="{{ sid }}" aria-label="{{ section.settings.aria_label | default: 'Customer quote' | escape }}">
  <div class="qm__container">
    {%- if section.settings.quote != blank -%}
      <p class="qm__quote">{{ section.settings.quote }}</p>
    {%- endif -%}
    {%- if section.settings.author != blank -%}
      <div class="qm__cite">
        <span class="qm__avatar" aria-hidden="true">
          {%- if section.settings.avatar != blank -%}
            {%- assign avatar_alt = section.settings.author | escape -%}
            {{ section.settings.avatar | image_url: width: 80 | image_tag: loading: 'lazy', alt: avatar_alt }}
          {%- else -%}
            {{ section.settings.author | slice: 0, 1 | upcase }}
          {%- endif -%}
        </span>
        <span><span class="qm__name">{{ section.settings.author }}</span>{%- if section.settings.author_meta != blank %} · {{ section.settings.author_meta }}{%- endif -%}</span>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Pull quote",
  "tag": "section",
  "class": "section section--master-quote",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "textarea", "id": "quote", "label": "Quote", "default": "I bought this with a lot of hesitation, but to my surprise it worked really well. Best results I've had. I rarely use mascara now." },
    { "type": "text", "id": "author", "label": "Author name", "default": "Emma D." },
    { "type": "text", "id": "author_meta", "label": "Author meta", "default": "Verified buyer" },
    { "type": "image_picker", "id": "avatar", "label": "Author avatar" },
    { "type": "text", "id": "aria_label", "label": "ARIA label" },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Section bg", "default": "#fbe9e8" },
    { "type": "color", "id": "text_color", "label": "Body text", "default": "#1a1a1a" },
    { "type": "color", "id": "quote_color", "label": "Quote color", "default": "#1a1a1a" },
    { "type": "color", "id": "muted_color", "label": "Cite color", "default": "#7a7a7a" },
    { "type": "color", "id": "accent_color", "label": "Quote marks accent", "default": "#e8a5a0" },
    { "type": "color", "id": "avatar_text_color", "label": "Avatar initial color", "default": "#ffffff" },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "quote_size_min", "label": "Quote min size", "min": 20, "max": 40, "step": 1, "unit": "px", "default": 24 },
    { "type": "range", "id": "quote_size_vw", "label": "Quote fluid (vw)", "min": 2, "max": 6, "step": 1, "unit": "vw", "default": 3 },
    { "type": "range", "id": "quote_size_max", "label": "Quote max size", "min": 28, "max": 56, "step": 1, "unit": "px", "default": 34 },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "max_width", "label": "Inner max width", "min": 600, "max": 1200, "step": 20, "unit": "px", "default": 900 },
    { "type": "range", "id": "side_padding", "label": "Side padding", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 40 }
  ],
  "presets": [
    { "name": "Pull quote" }
  ]
}
{% endschema %}
