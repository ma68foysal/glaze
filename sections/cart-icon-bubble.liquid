{%- comment -%}
  Thin section wrapper around snippets/cart-icon-bubble.liquid. Exists ONLY so
  the Shopify Section Rendering API can refetch this section's HTML on every
  cart mutation (called by glaze-cart.js with ?section_id=cart-icon-bubble).

  The actual markup lives in the snippet so it can also be rendered inline
  inside sections/header.liquid (where {% section %} would error with
  "Cannot render sections inside sections").
{%- endcomment -%}

{% render 'cart-icon-bubble' %}

{% schema %}
{
  "name": "Cart icon",
  "tag": "div",
  "settings": []
}
{% endschema %}
