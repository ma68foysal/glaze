{%- liquid
  assign section_id = 'glaze-pb-' | append: section.id
-%}

{%- comment -%}
  Per-instance CSS variables. Structural styles live in assets/base.css
  under "S10. Product bundle".
{%- endcomment -%}
<style>
  #{{ section_id }} {
    --pb-bg: {{ section.settings.bg_color }};
    --pb-fg: {{ section.settings.text_color }};
    --pb-eyebrow-c: {{ section.settings.eyebrow_color }};
    --pb-eyebrow-s: {{ section.settings.eyebrow_size }}px;
    --pb-title-c: {{ section.settings.title_color }};
    --pb-title-s: {{ section.settings.title_size }}px;
    --pb-title-w: {{ section.settings.title_weight }};
    --pb-radius: {{ section.settings.media_radius }}px;
    --pb-dot-bg: {{ section.settings.dot_bg }};
    --pb-dot-fg: {{ section.settings.dot_fg }};
    --pb-dot-size: {{ section.settings.dot_size }}px;
    --pb-item-bg: {{ section.settings.item_bg }};
    --pb-item-img-bg: {{ section.settings.item_image_bg }};
    --pb-num-bg: {{ section.settings.num_bg }};
    --pb-num-fg: {{ section.settings.num_fg }};
    --pb-item-title-c: {{ section.settings.item_title_color }};
    --pb-item-title-s: {{ section.settings.item_title_size }}px;
    --pb-price-c: {{ section.settings.price_color }};
    --pb-compare-c: {{ section.settings.compare_color }};
    --pb-variant-c: {{ section.settings.variant_color }};
    --pb-btn-bg: {{ section.settings.btn_bg }};
    --pb-btn-fg: {{ section.settings.btn_fg }};
    --pb-btn-hover-bg: {{ section.settings.btn_hover_bg }};
    --pb-btn-hover-fg: {{ section.settings.btn_hover_fg }};
    --pb-pad-top: {{ section.settings.padding_top }}px;
    --pb-pad-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>

<div id="{{ section_id }}" class="glaze-pb" data-glaze-pb>
  <div class="pb-wrap">
    <div class="pb-grid">

      <div class="pb-media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', alt: section.settings.title, widths: '400,600,800,1000,1400' }}
        {%- endif -%}

        {%- for block in section.blocks -%}
          {%- assign product = block.settings.product -%}
          {%- assign p_url = product.url | default: '#' -%}
          <a
            href="{{ p_url }}"
            class="pb-dot"
            data-pb-idx="{{ forloop.index0 }}"
            style="left: {{ block.settings.dot_x }}%; top: {{ block.settings.dot_y }}%;"
            aria-label="View {{ product.title | default: 'product' }}"
            {{ block.shopify_attributes }}
          >{{ forloop.index }}</a>
        {%- endfor -%}
      </div>

      <div class="pb-content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="pb-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="pb-title">{{ section.settings.title }}</h2>
        {%- endif -%}

        <div class="pb-items">
          {%- for block in section.blocks -%}
            {%- assign product = block.settings.product -%}
            {%- if product != blank -%}
              {%- assign override_title = block.settings.title_override -%}
              {%- assign disp_title = override_title | default: product.title -%}
              {%- assign first_variant = product.selected_or_first_available_variant -%}

              <div class="pb-item" data-pb-idx="{{ forloop.index0 }}" data-pb-variant-id="{{ first_variant.id }}" data-pb-available="{{ first_variant.available }}">
                <a href="{{ product.url }}" class="pb-item-num">{{ forloop.index }}</a>
                <a href="{{ product.url }}" class="pb-item-image" aria-hidden="true" tabindex="-1">
                  {%- if product.featured_image -%}
                    {{ product.featured_image | image_url: width: 200 | image_tag: loading: 'lazy', alt: disp_title, widths: '100,150,200' }}
                  {%- endif -%}
                </a>
                <div class="pb-item-details">
                  <div class="pb-item-head">
                    <a href="{{ product.url }}" class="pb-item-title">{{ disp_title }}</a>
                    <div class="pb-item-price" data-pb-price>
                      {{ first_variant.price | money }}
                      {%- if first_variant.compare_at_price > first_variant.price -%}
                        <span class="pb-item-price-compare">{{ first_variant.compare_at_price | money }}</span>
                      {%- endif -%}
                    </div>
                  </div>

                  {%- if product.variants.size > 1 -%}
                    <span class="pb-variant">
                      <select data-pb-variant="{{ forloop.index0 }}" data-product-handle="{{ product.handle }}" aria-label="{{ disp_title }} variant">
                        {%- for v in product.variants -%}
                          <option
                            value="{{ v.id }}"
                            data-price="{{ v.price }}"
                            data-compare="{{ v.compare_at_price | default: 0 }}"
                            data-available="{{ v.available }}"
                            {% if v.id == first_variant.id %}selected{% endif %}
                          >{{ v.title }}</option>
                        {%- endfor -%}
                      </select>
                    </span>
                  {%- elsif first_variant.title != 'Default Title' -%}
                    <span class="pb-variant" style="pointer-events:none;">
                      <select disabled><option>{{ first_variant.title }}</option></select>
                    </span>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.blocks.size > 0 -%}
          <div class="pb-cta-wrap">
            <button type="button" class="pb-cta" data-pb-add-all>
              <span>{{ section.settings.btn_label | default: 'Add All To Cart' }}</span>
            </button>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{%- comment -%}
  Hover sync + per-item variant pricing + Add-All-To-Cart live in
  assets/global.js as Glaze.productBundle, auto-initialised on the
  [data-glaze-pb] root element above.
{%- endcomment -%}

{% schema %}
{
  "name": "Product bundle",
  "class": "section-product-bundle-glaze",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Main image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "media_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Image corner radius",
      "default": 16
    },
    {
      "type": "header",
      "content": "Content (right side)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop Skincare Set"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Level up skincare routine with the bundle"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Add All To Cart"
    },
    {
      "type": "header",
      "content": "Section colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Default text",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Eyebrow"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Size",
      "default": 42
    },
    {
      "type": "range",
      "id": "title_weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "label": "Weight",
      "default": 600
    },
    {
      "type": "header",
      "content": "Dots on image"
    },
    {
      "type": "color",
      "id": "dot_bg",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "dot_fg",
      "label": "Text",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "dot_size",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Dot size",
      "default": 32
    },
    {
      "type": "header",
      "content": "Item row"
    },
    {
      "type": "color",
      "id": "item_bg",
      "label": "Row background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "item_image_bg",
      "label": "Thumbnail background",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "num_bg",
      "label": "Number circle background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "num_fg",
      "label": "Number color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "item_title_color",
      "label": "Item title color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "item_title_size",
      "min": 13,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Item title size",
      "default": 15
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "compare_color",
      "label": "Compare-at color",
      "default": "#999999"
    },
    {
      "type": "color",
      "id": "variant_color",
      "label": "Variant selector color",
      "default": "#555555"
    },
    {
      "type": "header",
      "content": "Add All button"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "btn_fg",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_hover_bg",
      "label": "Hover background",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "btn_hover_fg",
      "label": "Hover text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "title_override",
          "label": "Title override (optional)"
        },
        {
          "type": "header",
          "content": "Dot position"
        },
        {
          "type": "range",
          "id": "dot_x",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Horizontal position",
          "info": "0 = left edge, 100 = right edge.",
          "default": 50
        },
        {
          "type": "range",
          "id": "dot_y",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Vertical position",
          "info": "0 = top edge, 100 = bottom edge.",
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product bundle",
      "blocks": [
        { "type": "product", "settings": { "dot_x": 70, "dot_y": 45 } },
        { "type": "product", "settings": { "dot_x": 42, "dot_y": 65 } },
        { "type": "product", "settings": { "dot_x": 20, "dot_y": 38 } }
      ]
    }
  ]
}
{% endschema %}
