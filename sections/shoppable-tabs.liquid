{%- liquid
  assign section_id = 'glaze-st-' | append: section.id
-%}

{%- comment -%}
  Per-instance CSS variables. Structural styles live in assets/base.css
  under "S11. Shoppable tabs".
{%- endcomment -%}
<style>
  #{{ section_id }} {
    --st-bg: {{ section.settings.bg_color }};
    --st-fg: {{ section.settings.text_color }};
    --st-eyebrow-c: {{ section.settings.eyebrow_color }};
    --st-eyebrow-s: {{ section.settings.eyebrow_size }}px;
    --st-eyebrow-w: {{ section.settings.eyebrow_weight }};
    --st-title-c: {{ section.settings.title_color }};
    --st-title-s: {{ section.settings.title_size }}px;
    --st-title-w: {{ section.settings.title_weight }};
    --st-tab-title-c: {{ section.settings.tab_title_color }};
    --st-tab-title-inactive-c: {{ section.settings.tab_title_inactive_color }};
    --st-tab-title-s: {{ section.settings.tab_title_size }}px;
    --st-tab-title-w: {{ section.settings.tab_title_weight }};
    --st-tab-desc-c: {{ section.settings.tab_desc_color }};
    --st-tab-desc-s: {{ section.settings.tab_desc_size }}px;
    --st-tab-accent: {{ section.settings.tab_accent_color }};
    --st-card-radius: {{ section.settings.card_radius }}px;
    --st-prod-bg: {{ section.settings.product_bar_bg }};
    --st-prod-title-c: {{ section.settings.product_title_color }};
    --st-prod-title-s: {{ section.settings.product_title_size }}px;
    --st-prod-price-c: {{ section.settings.product_price_color }};
    --st-prod-compare-c: {{ section.settings.product_compare_color }};
    --st-prod-price-s: {{ section.settings.product_price_size }}px;
    --st-prod-thumb: {{ section.settings.product_thumb_size }}px;
    --st-bag-bg: {{ section.settings.bag_bg }};
    --st-bag-fg: {{ section.settings.bag_fg }};
    --st-bag-hover-bg: {{ section.settings.bag_hover_bg }};
    --st-bag-hover-fg: {{ section.settings.bag_hover_fg }};
    --st-sticky-top: {{ section.settings.sticky_offset }}px;
    --st-pad-top: {{ section.settings.padding_top }}px;
    --st-pad-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>

<div id="{{ section_id }}" class="glaze-st" data-glaze-st>
  <div class="st-wrap">

    {%- if section.settings.eyebrow != blank or section.settings.title != blank -%}
      <div class="st-head">
        {%- if section.settings.eyebrow != blank -%}
          <p class="st-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="st-title">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="st-body">

      <div class="st-tabs-col">
        {%- comment -%} Desktop tabs {%- endcomment -%}
        <div class="st-tabs" role="tablist">
          {%- for block in section.blocks -%}
            <button
              type="button"
              class="st-tab{% if forloop.first %} is-active{% endif %}"
              data-st-tab="{{ forloop.index0 }}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              {{ block.shopify_attributes }}
            >
              <h3 class="st-tab-title">{{ block.settings.tab_title | default: 'Tab' }}</h3>
              {%- if block.settings.tab_description != blank -%}
                <div class="st-tab-desc">{{ block.settings.tab_description }}</div>
              {%- endif -%}
            </button>
          {%- endfor -%}
        </div>

        {%- comment -%} Mobile select {%- endcomment -%}
        <div class="st-mobile-tabs">
          <label for="{{ section.id }}-tab-select" class="visually-hidden">{{ section.settings.title | default: 'Choose a tab' | escape }}</label>
          <select id="{{ section.id }}-tab-select" class="st-select" data-st-select aria-label="{{ section.settings.title | default: 'Choose a tab' | escape }}">
            {%- for block in section.blocks -%}
              <option value="{{ forloop.index0 }}"{% if forloop.first %} selected{% endif %}>{{ block.settings.tab_title | default: 'Tab' }}</option>
            {%- endfor -%}
          </select>
          <div class="st-mobile-desc" data-st-mobile-desc>
            {%- if section.blocks.first.settings.tab_description != blank -%}
              {{ section.blocks.first.settings.tab_description }}
            {%- endif -%}
          </div>
        </div>
      </div>

      <div class="st-panels">
        {%- for block in section.blocks -%}
          {%- assign coll = block.settings.collection -%}
          {%- assign count = block.settings.products_count | default: 4 -%}
          <div
            class="st-panel{% if forloop.first %} is-active{% endif %}"
            data-st-panel="{{ forloop.index0 }}"
            role="tabpanel"
          >
            <div class="st-grid">
              {%- if coll != blank and coll.products.size > 0 -%}
                {%- for product in coll.products limit: count -%}
                  {%- assign v = product.selected_or_first_available_variant -%}
                  {%- assign lifestyle = product.images[1] | default: product.featured_image -%}
                  {%- assign has_variants = false -%}
                  {%- if product.variants.size > 1 or product.has_only_default_variant == false -%}{%- assign has_variants = true -%}{%- endif -%}

                  <a href="{{ product.url }}" class="st-card" data-handle="{{ product.handle }}">
                    <div class="st-card-media">
                      {%- if lifestyle -%}
                        {{ lifestyle | image_url: width: 800 | image_tag: loading: 'lazy', alt: product.title, widths: '300,500,700,800' }}
                      {%- endif -%}
                    </div>
                    <div class="st-prod">
                      <div class="st-prod-thumb">
                        {%- if product.featured_image -%}
                          {{ product.featured_image | image_url: width: 160 | image_tag: loading: 'lazy', alt: product.title, widths: '80,120,160' }}
                        {%- endif -%}
                      </div>
                      <div class="st-prod-info">
                        <p class="st-prod-title">{{ product.title }}</p>
                        <p class="st-prod-price">
                          {%- if product.price_varies -%}From {% endif -%}{{ v.price | money }}
                          {%- if v.compare_at_price > v.price -%}
                            <span class="st-prod-price-compare">{{ v.compare_at_price | money }}</span>
                          {%- endif -%}
                        </p>
                      </div>
                      <button
                        type="button"
                        class="st-bag-btn"
                        {% if has_variants %}
                          data-st-goto="{{ product.url }}"
                          aria-label="Choose options for {{ product.title }}"
                        {% else %}
                          data-st-atc="{{ v.id }}"
                          aria-label="Add {{ product.title }} to cart"
                          {% if v.available == false %}disabled{% endif %}
                        {% endif %}
                      >
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                          <path d="M5 8h14l-1.2 11a2 2 0 0 1-2 1.8H8.2a2 2 0 0 1-2-1.8L5 8zM9 8a3 3 0 0 1 6 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                    </div>
                  </a>
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>
</div>

{%- comment -%}
  Tab switcher + ATC handler live in assets/global.js as Glaze.shoppableTabs,
  auto-initialised on the [data-glaze-st] root element above.
{%- endcomment -%}

{% schema %}
{
  "name": "Shoppable tabs",
  "class": "section-shoppable-tabs-glaze",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Photos and videos"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Eyebrow size",
      "default": 14
    },
    {
      "type": "range",
      "id": "eyebrow_weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "label": "Eyebrow weight",
      "default": 500
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Customers enjoy their journey everyday"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 22,
      "max": 64,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 38
    },
    {
      "type": "range",
      "id": "title_weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "label": "Title weight",
      "default": 600
    },
    {
      "type": "header",
      "content": "Tabs (left column)"
    },
    {
      "type": "color",
      "id": "tab_title_color",
      "label": "Active title color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "tab_title_inactive_color",
      "label": "Inactive title color",
      "default": "#a0a0a0"
    },
    {
      "type": "range",
      "id": "tab_title_size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Title size",
      "default": 18
    },
    {
      "type": "range",
      "id": "tab_title_weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "label": "Title weight",
      "default": 600
    },
    {
      "type": "color",
      "id": "tab_desc_color",
      "label": "Description color",
      "default": "#3a3a3a"
    },
    {
      "type": "range",
      "id": "tab_desc_size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 14
    },
    {
      "type": "color",
      "id": "tab_accent_color",
      "label": "Active accent (left border)",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "sticky_offset",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Sticky top offset",
      "default": 80
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Card radius",
      "default": 16
    },
    {
      "type": "header",
      "content": "Product bar"
    },
    {
      "type": "color",
      "id": "product_bar_bg",
      "label": "Bar background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "product_thumb_size",
      "min": 36,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Thumbnail size",
      "default": 54
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Title color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "product_title_size",
      "min": 11,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Title size",
      "default": 14
    },
    {
      "type": "color",
      "id": "product_price_color",
      "label": "Price color",
      "default": "#e23b3b"
    },
    {
      "type": "color",
      "id": "product_compare_color",
      "label": "Compare-at color",
      "default": "#8a8a8a"
    },
    {
      "type": "range",
      "id": "product_price_size",
      "min": 11,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Price size",
      "default": 13
    },
    {
      "type": "header",
      "content": "Bag button"
    },
    {
      "type": "color",
      "id": "bag_bg",
      "label": "Background",
      "default": "#f2f2f2"
    },
    {
      "type": "color",
      "id": "bag_fg",
      "label": "Icon color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "bag_hover_bg",
      "label": "Hover background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "bag_hover_fg",
      "label": "Hover icon color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Default text",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab title",
          "default": "Safe for Sensitive Skin"
        },
        {
          "type": "richtext",
          "id": "tab_description",
          "label": "Tab description",
          "default": "<p>We're strict about what goes into our products (and what stays out). Our therapist calls it setting healthy boundaries.</p>"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "range",
          "id": "products_count",
          "min": 2,
          "max": 8,
          "step": 1,
          "label": "Products to show",
          "default": 4
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shoppable tabs",
      "blocks": [
        { "type": "tab", "settings": { "tab_title": "Safe for Sensitive Skin" } },
        { "type": "tab", "settings": { "tab_title": "Safe for Dry Skin" } },
        { "type": "tab", "settings": { "tab_title": "Organic Skincare" } },
        { "type": "tab", "settings": { "tab_title": "High-End Products" } }
      ]
    }
  ]
}
{% endschema %}
