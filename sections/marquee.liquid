{%- liquid
  assign section_id = 'glaze-mq-' | append: section.id
  if section.settings.direction == 'right'
    assign direction_value = 'reverse'
  else
    assign direction_value = 'normal'
  endif
-%}

{%- comment -%}
  Per-instance CSS variables. Structural styles live in assets/base.css
  under "S5. Marquee".
{%- endcomment -%}
<style>
  #{{ section_id }} {
    --mq-bg: {{ section.settings.bg_color }};
    --mq-text-c: {{ section.settings.text_color }};
    --mq-text-s: {{ section.settings.text_size }}px;
    --mq-text-s-mobile: {{ section.settings.text_size_mobile }}px;
    --mq-text-w: {{ section.settings.text_weight }};
    --mq-img-size: {{ section.settings.image_size }}px;
    --mq-img-size-mobile: {{ section.settings.image_size_mobile }}px;
    --mq-img-radius: {{ section.settings.image_radius }}px;
    --mq-gap: {{ section.settings.gap }}px;
    --mq-gap-mobile: {{ section.settings.gap_mobile }}px;
    --mq-border-top-w: {{ section.settings.border_top_width }}px;
    --mq-border-top-c: {{ section.settings.border_top_color }};
    --mq-border-bottom-w: {{ section.settings.border_bottom_width }}px;
    --mq-border-bottom-c: {{ section.settings.border_bottom_color }};
    --mq-pad-top: {{ section.settings.padding_top }}px;
    --mq-pad-bottom: {{ section.settings.padding_bottom }}px;
    --mq-speed: {{ section.settings.speed }}s;
    --mq-direction: {{ direction_value }};
  }
</style>

<div id="{{ section_id }}" class="glaze-mq" data-glaze-mq>
  <div class="mq-viewport">
    <div class="mq-track" data-mq-track>
      {%- comment -%} Render blocks twice for seamless infinite loop {%- endcomment -%}
      {%- for i in (1..2) -%}
        {%- for block in section.blocks -%}
          {%- capture inner -%}
            {%- if block.settings.image != blank -%}
              <span class="mq-image">
                {{ block.settings.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: block.settings.text, widths: '80,120,160,200' }}
              </span>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <span class="mq-text">{{ block.settings.text }}</span>
            {%- endif -%}
          {%- endcapture -%}

          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="mq-item" {% if i == 1 %}{{ block.shopify_attributes }}{% else %}aria-hidden="true" tabindex="-1"{% endif %}>{{ inner }}</a>
          {%- else -%}
            <div class="mq-item" {% if i == 1 %}{{ block.shopify_attributes }}{% else %}aria-hidden="true"{% endif %}>{{ inner }}</div>
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Marquee",
  "class": "section-marquee-glaze",
  "tag": "section",
  "max_blocks": 20,
  "settings": [
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "options": [
        { "value": "left", "label": "Left (→)" },
        { "value": "right", "label": "Right (←)" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 120,
      "step": 2,
      "unit": "s",
      "label": "Scroll duration",
      "info": "Lower = faster. Higher = slower.",
      "default": 40
    },
    {
      "type": "paragraph",
      "content": "Marquee pauses automatically on hover. Also respects the user's reduced-motion preference."
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 14,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Size (desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Size (mobile)",
      "default": 22
    },
    {
      "type": "range",
      "id": "text_weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "label": "Weight",
      "default": 500
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "range",
      "id": "image_size",
      "min": 30,
      "max": 160,
      "step": 2,
      "unit": "px",
      "label": "Size (desktop)",
      "default": 72
    },
    {
      "type": "range",
      "id": "image_size_mobile",
      "min": 24,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Size (mobile)",
      "default": 46
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Radius",
      "info": "Set to half the image size for a perfect circle.",
      "default": 80
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 10,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Gap between items (desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "min": 8,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Gap between items (mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 24
    },
    {
      "type": "header",
      "content": "Section colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Top border"
    },
    {
      "type": "range",
      "id": "border_top_width",
      "min": 0,
      "max": 8,
      "step": 1,
      "unit": "px",
      "label": "Thickness",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_top_color",
      "label": "Color",
      "default": "#e6e6e6"
    },
    {
      "type": "header",
      "content": "Bottom border"
    },
    {
      "type": "range",
      "id": "border_bottom_width",
      "min": 0,
      "max": 8,
      "step": 1,
      "unit": "px",
      "label": "Thickness",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_bottom_color",
      "label": "Color",
      "default": "#e6e6e6"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "New Season Essential"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee",
      "blocks": [
        { "type": "item", "settings": { "text": "Rescue Your Skin" } },
        { "type": "item", "settings": { "text": "Made with love" } },
        { "type": "item", "settings": { "text": "New Season Essential" } },
        { "type": "item", "settings": { "text": "Clean Ingredients" } }
      ]
    }
  ]
}
{% endschema %}
