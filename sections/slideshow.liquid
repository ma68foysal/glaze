{%- liquid
  assign section_id = 'sleek-slideshow-' | append: section.id
  assign autoplay = section.settings.autoplay
  assign speed = section.settings.speed
  assign height_dt = section.settings.height_desktop
  assign height_mb = section.settings.height_mobile
  assign show_dots = section.settings.show_dots
-%}

<style>
  /* ============================================================
     Slideshow Sleek — scoped styles
     ============================================================ */

  #{{ section_id }} {
    --sleek-ss-height-dt: {{ height_dt }}px;
    --sleek-ss-height-mb: {{ height_mb }}px;
    --sleek-ss-gap: {{ section.settings.content_gap }}px;
    --sleek-ss-radius: {{ section.settings.corner_radius }}px;
    --sleek-ss-dot-color: {{ section.settings.dot_color }};
    --sleek-ss-dot-active: {{ section.settings.dot_active_color }};
    --sleek-ss-pad: {{ section.settings.section_padding }}px;
    --sleek-ss-peek: {{ section.settings.peek }}px;
    --sleek-ss-slide-gap: {{ section.settings.slide_gap }}px;
    display: block;
    position: relative;
    padding: var(--sleek-ss-pad) 0;
    overflow: hidden;
  }

  .sleek-ss-wrap { overflow: hidden; }

  #{{ section_id }} *,
  #{{ section_id }} *::before,
  #{{ section_id }} *::after {
    box-sizing: border-box;
  }

  .sleek-ss-wrap {
    position: relative;
    width: 100%;
  }

  .sleek-ss-viewport {
    position: relative;
    width: 100%;
    height: var(--sleek-ss-height-dt);
    overflow: hidden;
  }

  .sleek-ss-track {
    display: flex;
    height: 100%;
    width: 100%;
    padding: 0 var(--sleek-ss-peek);
    gap: var(--sleek-ss-slide-gap);
    transition: transform 0.8s cubic-bezier(0.65, 0, 0.35, 1);
    will-change: transform;
  }

  .sleek-slide {
    flex: 0 0 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
    border-radius: var(--sleek-ss-radius);
  }

  .sleek-slide__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #f0ecea;
    z-index: 1;
  }

  .sleek-slide__media picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .sleek-slide__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.04);
    transition: transform 6s ease-out;
  }

  .sleek-slide.is-active .sleek-slide__media img { transform: scale(1); }

  .sleek-slide__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .sleek-slide__content {
    position: absolute;
    inset: 0;
    z-index: 3;
    padding: clamp(24px, 5vw, 72px);
    display: flex;
    flex-direction: column;
    gap: var(--sleek-ss-gap);
    pointer-events: none;
    
  }

  .sleek-slide__content > * { pointer-events: auto; }

  .sleek-slide__content-inner {
    display: flex;
    flex-direction: column;
    gap: var(--sleek-ss-gap);
    max-width: min(var(--slide-content-width, 460px), 90%);
    width: 100%;
  }

  .sleek-slide[data-v-pos="top"] .sleek-slide__content { justify-content: flex-start; }
  .sleek-slide[data-v-pos="middle"] .sleek-slide__content { justify-content: center; }
  .sleek-slide[data-v-pos="bottom"] .sleek-slide__content { justify-content: flex-end; }

  .sleek-slide[data-h-align="left"] .sleek-slide__content { align-items: flex-start; }
  .sleek-slide[data-h-align="center"] .sleek-slide__content { align-items: center; }
  .sleek-slide[data-h-align="right"] .sleek-slide__content { align-items: flex-end; }

  .sleek-slide[data-h-align="left"] .sleek-slide__content-inner { text-align: left; align-items: flex-start; }
  .sleek-slide[data-h-align="center"] .sleek-slide__content-inner { text-align: center; align-items: center; }
  .sleek-slide[data-h-align="right"] .sleek-slide__content-inner { text-align: right; align-items: flex-end; }

  /* Stagger-in for text */
  .sleek-slide__eyebrow,
  .sleek-slide__heading,
  .sleek-slide__sub,
  .sleek-slide__cta {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1), transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .sleek-slide.is-active .sleek-slide__eyebrow { opacity: 1; transform: translateY(0); transition-delay: 0.15s; }
  .sleek-slide.is-active .sleek-slide__heading { opacity: 1; transform: translateY(0); transition-delay: 0.28s; }
  .sleek-slide.is-active .sleek-slide__sub { opacity: 1; transform: translateY(0); transition-delay: 0.40s; }
  .sleek-slide.is-active .sleek-slide__cta { opacity: 1; transform: translateY(0); transition-delay: 0.52s; }

  .sleek-slide__eyebrow {
    font-size: 14px;
    letter-spacing: 0.04em;
    margin: 0;
    opacity: 0.85;
  }

  .sleek-slide__heading {
    font-size: clamp(28px, 4.4vw, 64px);
    line-height: 1.05;
    font-weight: 600;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .sleek-slide__sub {
    font-size: 16px;
    line-height: 1.5;
    max-width: 46ch;
    margin: 0;
  }

  .sleek-slide__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 999px;
    background: #111;
    color: #fff;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: transform 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
  }

  .sleek-slide__cta:hover {
    background: #222;
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.14);
  }

  /* -------- Dots / progress bar (below the bg container) -------- */
  .sleek-ss-dots {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 20px auto 0;
    width: 100%;
    padding: 0;
  }

  .sleek-ss-dot {
    position: relative;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--sleek-ss-dot-color);
    border: 0;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    transition: width 0.5s cubic-bezier(0.22, 1, 0.36, 1), background 0.3s ease;
    flex-shrink: 0;
  }

  .sleek-ss-dot.is-active {
    width: 48px;
    background: var(--sleek-ss-dot-color);
  }

  .sleek-ss-dot-fill {
    position: absolute;
    inset: 0;
    width: 0%;
    background: var(--sleek-ss-dot-active);
    transition: none;
  }

  .sleek-ss-dot.is-active .sleek-ss-dot-fill {
    animation: sleek-ss-fill {{ speed }}s linear forwards;
  }

  @keyframes sleek-ss-fill {
    from { width: 0%; }
    to { width: 100%; }
  }

  /* -------- Arrows (optional) -------- */
  .sleek-ss-arrows {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    padding: 0 24px;
    pointer-events: none;
    z-index: 4;
  }

  .sleek-ss-arrow {
    pointer-events: auto;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.9);
    color: #111;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.25s ease;
    backdrop-filter: blur(6px);
  }

  .sleek-ss-arrow:hover {
    background: #fff;
    transform: scale(1.05);
  }

  .sleek-ss-arrow svg { width: 16px; height: 16px; }

  /* -------- Responsive -------- */
  @media screen and (max-width: 768px) {
    .sleek-ss-viewport { height: auto; overflow: hidden; }
    .sleek-ss-track {
      height: auto;
      padding: 0 16px;
      gap: 12px;
    }

    .sleek-slide {
      display: flex;
      flex-direction: column;
      min-height: auto;
      background: transparent !important;
      overflow: hidden;
      border-radius: 0;
    }

    .sleek-slide__media {
      position: relative;
      inset: auto;
      width: 100%;
      aspect-ratio: 1 / 1;
      flex: 0 0 auto;
      order: 1;
      background: transparent;
      border-radius: var(--sleek-ss-radius);
      overflow: hidden;
    }

    .sleek-slide__content {
      position: relative;
      inset: auto;
      padding: 24px 8px 8px;
      justify-content: flex-start;
      align-items: center !important;
      flex: 0 0 auto;
      order: 2;
    }

    .sleek-slide__content-inner {
      max-width: 100%;
      text-align: center !important;
      align-items: center !important;
    }

    .sleek-slide__heading { font-size: clamp(24px, 7vw, 36px); }
    .sleek-ss-arrows { display: none; }

    .sleek-slide[data-mobile-stack="content-first"] .sleek-slide__media { order: 2; }
    .sleek-slide[data-mobile-stack="content-first"] .sleek-slide__content { order: 1; padding: 8px 8px 24px; }
  }
</style>

<div
  id="{{ section_id }}"
  class="sleek-slideshow"
  data-sleek-slideshow
  data-autoplay="{% if autoplay %}1{% else %}0{% endif %}"
  data-speed="{{ speed }}"
>
  <div class="sleek-ss-wrap">
    <div class="sleek-ss-viewport">
      <div class="sleek-ss-track" data-ss-track>
        {%- for block in section.blocks -%}
          {%- liquid
            assign bg = block.settings.bg_color
            assign text_color = block.settings.text_color
            assign image_side = block.settings.image_side
            assign v_pos = block.settings.content_v_position
            assign h_align = block.settings.content_h_align
            assign overlay_type = block.settings.overlay_type
            assign overlay_color = block.settings.overlay_color
            assign overlay_opacity = block.settings.overlay_opacity | divided_by: 100.0
            assign layout = block.settings.layout
            assign mobile_stack = block.settings.mobile_stack
          -%}
          <div
            class="sleek-slide{% if forloop.first %} is-active{% endif %}"
            data-image-side="{{ image_side }}"
            data-v-pos="{{ v_pos }}"
            data-h-align="{{ h_align }}"
            data-layout="{{ layout }}"
            data-mobile-stack="{{ mobile_stack }}"
            style="background-color: {{ bg }}; color: {{ text_color }}; --slide-content-width: {{ block.settings.content_width }}px;"
            {{ block.shopify_attributes }}
          >
            <div class="sleek-slide__media">
              {%- if block.settings.image != blank or block.settings.image_mobile != blank -%}
                {%- assign desktop_img = block.settings.image -%}
                {%- assign mobile_img = block.settings.image_mobile | default: block.settings.image -%}
                {%- if desktop_img == blank -%}{%- assign desktop_img = mobile_img -%}{%- endif -%}
                <picture>
                  {%- if mobile_img != blank -%}
                    <source media="(max-width: 767px)" srcset="{{ mobile_img | image_url: width: 400 }} 400w, {{ mobile_img | image_url: width: 600 }} 600w, {{ mobile_img | image_url: width: 800 }} 800w, {{ mobile_img | image_url: width: 1000 }} 1000w">
                  {%- endif -%}
                  {%- if forloop.first -%}
                    {{
                      desktop_img
                      | image_url: width: 1600
                      | image_tag:
                        loading: 'eager',
                        fetchpriority: 'high',
                        widths: '600,800,1200,1600,2000',
                        sizes: '100vw',
                        alt: block.settings.heading | default: shop.name
                    }}
                  {%- else -%}
                    {{
                      desktop_img
                      | image_url: width: 1600
                      | image_tag:
                        loading: 'lazy',
                        widths: '600,800,1200,1600,2000',
                        sizes: '100vw',
                        alt: block.settings.heading | default: shop.name
                    }}
                  {%- endif -%}
                </picture>
              {%- endif -%}

              {%- if overlay_type != 'none' -%}
                {%- assign ovc = overlay_color -%}
                {%- case overlay_type -%}
                  {%- when 'solid' -%}
                    <div
                      class="sleek-slide__overlay"
                      style="background: {{ ovc }}; opacity: {{ overlay_opacity }};"
                    ></div>
                  {%- when 'gradient_bottom' -%}
                    <div
                      class="sleek-slide__overlay"
                      style="background: linear-gradient(to top, {{ ovc }}, transparent); opacity: {{ overlay_opacity }};"
                    ></div>
                  {%- when 'gradient_top' -%}
                    <div
                      class="sleek-slide__overlay"
                      style="background: linear-gradient(to bottom, {{ ovc }}, transparent); opacity: {{ overlay_opacity }};"
                    ></div>
                  {%- when 'gradient_left' -%}
                    <div
                      class="sleek-slide__overlay"
                      style="background: linear-gradient(to right, {{ ovc }}, transparent); opacity: {{ overlay_opacity }};"
                    ></div>
                  {%- when 'gradient_right' -%}
                    <div
                      class="sleek-slide__overlay"
                      style="background: linear-gradient(to left, {{ ovc }}, transparent); opacity: {{ overlay_opacity }};"
                    ></div>
                {%- endcase -%}
              {%- endif -%}
            </div>

            <div class="sleek-slide__content">
              <div class="sleek-slide__content-inner">
                {%- if block.settings.eyebrow != blank -%}
                  <p class="sleek-slide__eyebrow">{{ block.settings.eyebrow }}</p>
                {%- endif -%}
                {%- if block.settings.heading != blank -%}
                  <h2 class="sleek-slide__heading">{{ block.settings.heading }}</h2>
                {%- endif -%}
                {%- if block.settings.sub != blank -%}
                  <p class="sleek-slide__sub">{{ block.settings.sub }}</p>
                {%- endif -%}
                {%- if block.settings.button_label != blank -%}
                  <a
                    href="{{ block.settings.button_link | default: '#' }}"
                    class="sleek-slide__cta"
                    style="background: {{ block.settings.button_bg }}; color: {{ block.settings.button_fg }};"
                  >
                    {{ block.settings.button_label }}
                  </a>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.show_arrows and section.blocks.size > 1 -%}
        <div class="sleek-ss-arrows">
          <button type="button" class="sleek-ss-arrow" data-ss-prev aria-label="Previous slide">
            <svg viewBox="0 0 16 16" fill="none">
              <path d="M10 2L4 8l6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button type="button" class="sleek-ss-arrow" data-ss-next aria-label="Next slide">
            <svg viewBox="0 0 16 16" fill="none">
              <path d="M6 2l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      {%- endif -%}
    </div>

    {%- if show_dots and section.blocks.size > 1 -%}
      <div class="sleek-ss-dots" role="tablist">
        {%- for block in section.blocks -%}
          <button
            type="button"
            class="sleek-ss-dot{% if forloop.first %} is-active{% endif %}"
            data-ss-dot="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"
          >
            <span class="sleek-ss-dot-fill"></span>
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('{{ section_id }}');
    if (!root) return;

    var track = root.querySelector('[data-ss-track]');
    var originals = Array.prototype.slice.call(track.querySelectorAll('.sleek-slide'));
    var dots = root.querySelectorAll('.sleek-ss-dot');
    var prev = root.querySelector('[data-ss-prev]');
    var next = root.querySelector('[data-ss-next]');
    var realTotal = originals.length;
    if (!realTotal) return;

    var autoplay = root.getAttribute('data-autoplay') === '1';
    var speed = parseFloat(root.getAttribute('data-speed')) || 5;
    var infinite = realTotal > 1;
    var transitionMs = 800;

    // Clone first and last slides for seamless looping
    if (infinite) {
      var firstClone = originals[0].cloneNode(true);
      var lastClone = originals[realTotal - 1].cloneNode(true);
      firstClone.setAttribute('aria-hidden', 'true');
      firstClone.setAttribute('data-clone', '1');
      firstClone.classList.remove('is-active');
      lastClone.setAttribute('aria-hidden', 'true');
      lastClone.setAttribute('data-clone', '1');
      lastClone.classList.remove('is-active');
      track.appendChild(firstClone);
      track.insertBefore(lastClone, originals[0]);
    }

    var slides = track.querySelectorAll('.sleek-slide');
    var total = slides.length;
    var offset = infinite ? 1 : 0;
    var current = offset;
    var timer = null;
    var teleportTimer = null;

    function computeStep() {
      if (!slides.length) return 0;
      var rect = slides[0].getBoundingClientRect();
      var gapVal = parseFloat(getComputedStyle(track).columnGap || getComputedStyle(track).gap || '0') || 0;
      return rect.width + gapVal;
    }

    function applyTransform(animate) {
      var step = computeStep();
      if (animate === false) {
        track.style.transition = 'none';
        track.style.transform = 'translateX(' + (-current * step) + 'px)';
        void track.offsetWidth;
        track.style.transition = '';
      } else {
        track.style.transition = '';
        track.style.transform = 'translateX(' + (-current * step) + 'px)';
      }
    }

    function getRealIdx() {
      if (!infinite) return current;
      if (current === 0) return realTotal - 1;       // on lastClone
      if (current === total - 1) return 0;           // on firstClone
      return current - 1;
    }

    function updateUi() {
      var realIdx = getRealIdx();
      var realElIdx = offset + realIdx;
      slides.forEach(function (s, i) {
        // Active = visually-current slide OR the real slide that corresponds to it.
        // Keeping the real slide active during a clone-frame means no flicker after teleport.
        s.classList.toggle('is-active', i === current || i === realElIdx);
      });
      dots.forEach(function (d, i) {
        var fill = d.querySelector('.sleek-ss-dot-fill');
        if (fill) {
          fill.style.animation = 'none';
          void fill.offsetWidth;
          fill.style.animation = '';
        }
        d.classList.toggle('is-active', i === realIdx);
      });
    }

    function goTo(idx) {
      if (teleportTimer) { clearTimeout(teleportTimer); teleportTimer = null; }
      current = idx;
      applyTransform(true);
      updateUi();

      // After transition, silently teleport from clone back to real slide
      if (infinite && (current === 0 || current === total - 1)) {
        teleportTimer = setTimeout(function () {
          if (current === 0) current = realTotal;
          else if (current === total - 1) current = 1;
          applyTransform(false);
          // Refresh active classes so the off-screen clone loses .is-active
          // and only the visible real slide keeps it (text stays visible).
          slides.forEach(function (s, i) { s.classList.toggle('is-active', i === current); });
          teleportTimer = null;
        }, transitionMs);
      }

      restartAutoplay();
    }

    function goToReal(realIdx) { goTo(offset + realIdx); }
    function nextSlide() { goTo(current + 1); }
    function prevSlide() { goTo(current - 1); }

    function startAutoplay() {
      if (!autoplay || realTotal < 2) return;
      stopAutoplay();
      timer = setTimeout(nextSlide, speed * 1000);
    }

    function stopAutoplay() {
      if (timer) { clearTimeout(timer); timer = null; }
    }

    function restartAutoplay() { stopAutoplay(); startAutoplay(); }

    dots.forEach(function (d) {
      d.addEventListener('click', function () {
        var idx = parseInt(d.getAttribute('data-ss-dot'), 10);
        if (!isNaN(idx)) goToReal(idx);
      });
    });

    if (next) next.addEventListener('click', nextSlide);
    if (prev) prev.addEventListener('click', prevSlide);

    document.addEventListener('visibilitychange', function () {
      if (document.hidden) stopAutoplay();
      else startAutoplay();
    });

    // Swipe on touch
    var startX = 0, dx = 0, dragging = false;
    root.addEventListener('touchstart', function (e) {
      if (!e.touches || !e.touches[0]) return;
      startX = e.touches[0].clientX;
      dragging = true;
      stopAutoplay();
    }, { passive: true });
    root.addEventListener('touchmove', function (e) {
      if (!dragging || !e.touches || !e.touches[0]) return;
      dx = e.touches[0].clientX - startX;
    }, { passive: true });
    root.addEventListener('touchend', function () {
      if (!dragging) return;
      dragging = false;
      if (Math.abs(dx) > 40) { dx < 0 ? nextSlide() : prevSlide(); }
      else { startAutoplay(); }
      dx = 0;
    });

    // Re-snap on resize
    var resizeTimer = null;
    window.addEventListener('resize', function () {
      if (resizeTimer) clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () { applyTransform(false); }, 80);
    });

    // Kickoff
    applyTransform(false);
    updateUi();
    startAutoplay();
  })();
</script>

{% schema %}
{
  "name": "Slideshow",
  "class": "section-slideshow-sleek",
  "tag": "section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 360,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Desktop height",
      "default": 620
    },
    {
      "type": "range",
      "id": "height_mobile",
      "min": 300,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Mobile height",
      "default": 560
    },
    {
      "type": "range",
      "id": "corner_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Slide corner radius",
      "default": 14
    },
    {
      "type": "range",
      "id": "peek",
      "min": 0,
      "max": 240,
      "step": 8,
      "unit": "px",
      "label": "Side peek (shows adjacent slides)",
      "info": "Distance from each side where the previous / next slide peeks in.",
      "default": 96
    },
    {
      "type": "range",
      "id": "slide_gap",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Gap between slides",
      "default": 16
    },
    {
      "type": "range",
      "id": "content_gap",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Text spacing",
      "default": 18
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Section padding",
      "default": 20
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
