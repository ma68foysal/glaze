{%- liquid
  assign sid = 'glaze-hero-' | append: section.id
  assign autoplay = section.settings.autoplay
  assign speed = section.settings.speed | default: 6
  assign h_desk = section.settings.height_desktop | default: 720
  assign h_mob = section.settings.height_mobile | default: 580
  assign parallax = section.settings.parallax_strength | default: 40
  assign show_progress = section.settings.show_progress
  assign show_counter = section.settings.show_counter
-%}

{% comment %}
  Glaze editorial hero — asymmetric magazine-spread slideshow.
  Image takes one side, cream-textured content panel takes the other.
  Slides crossfade (not horizontal slide), text reveals with mask wipes,
  numbered nav with autoplay progress bars at the side.
  All motion gated on prefers-reduced-motion. Pauses when out of viewport.

  Block-level "theme" preset swaps surface colors smoothly across slides
  (cream / blush / sage / ivory / ink / custom).
{% endcomment %}

<section
  id="{{ sid }}"
  class="glaze-hero"
  data-glaze-hero
  data-autoplay="{{ autoplay }}"
  data-speed="{{ speed }}"
  aria-roledescription="carousel"
  aria-label="{{ section.settings.aria_label | default: 'Featured stories' }}"
  style="--hero-h-desk: {{ h_desk }}px; --hero-h-mob: {{ h_mob }}px;"
>
  <div class="glaze-hero__stage" data-hero-stage>
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}
        {%- assign theme = block.settings.theme_preset | default: 'cream' -%}
        {%- assign align = block.settings.content_align | default: 'right' -%}
        {%- assign media_type = block.settings.media_type | default: 'image' -%}
        {%- assign has_video = false -%}
        {%- if media_type == 'video' and block.settings.video != blank -%}
          {%- assign has_video = true -%}
        {%- endif -%}
        <article
          class="glaze-hero__slide {% if forloop.first %}is-active{% endif %}"
          data-slide-index="{{ forloop.index0 }}"
          data-theme="{{ theme }}"
          data-align="{{ align }}"
          data-media="{% if has_video %}video{% else %}image{% endif %}"
          role="group"
          aria-roledescription="slide"
          aria-label="{{ forloop.index }} of {{ section.blocks.size }}"
          {% unless forloop.first %}aria-hidden="true"{% endunless %}
          {% if theme == 'custom' %}style="--hero-surface: {{ block.settings.bg_color }}; --hero-ink: {{ block.settings.text_color }};"{% endif %}
          {{ block.shopify_attributes }}
        >
          <div class="glaze-hero__media">
            <div class="glaze-hero__media-inner" data-parallax style="--parallax-strength: {{ parallax }};">
              {%- if has_video -%}
                {%- comment -%}
                  Shopify-hosted video. Image (if set) doubles as poster so
                  the first paint is instant. autoplay+muted+loop+playsinline
                  is required for the video to start without user interaction
                  on iOS Safari. First slide preloads fully; others preload
                  metadata only (saves bandwidth on multi-slide heroes).
                {%- endcomment -%}
                {% capture poster_url %}{% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 1600 }}{% endif %}{% endcapture %}
                {% capture vid_preload %}{% if forloop.first %}auto{% else %}metadata{% endif %}{% endcapture %}
                {% # theme-check-disable RemoteAsset %}
                <video
                  class="glaze-hero__img glaze-hero__video"
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="{{ vid_preload }}"
                  {% if poster_url != blank %}poster="{{ poster_url }}"{% endif %}
                  aria-label="{{ block.settings.heading | default: shop.name | escape }}"
                >
                  {%- for source in block.settings.video.sources -%}
                    <source src="{{ source.url }}" type="{{ source.mime_type }}">
                  {%- endfor -%}
                </video>
                {% # theme-check-enable RemoteAsset %}
              {%- elsif block.settings.image != blank -%}
                {%- assign img_alt = block.settings.heading | default: shop.name | escape -%}
                {% capture img_loading %}{% if forloop.first %}eager{% else %}lazy{% endif %}{% endcapture %}
                {% capture img_fetchpriority %}{% if forloop.first %}high{% else %}auto{% endif %}{% endcapture %}
                {{
                  block.settings.image
                  | image_url: width: 2400
                  | image_tag:
                    loading: img_loading,
                    fetchpriority: img_fetchpriority,
                    widths: '600, 900, 1200, 1600, 2000, 2400',
                    sizes: '(min-width: 900px) 62vw, 100vw',
                    class: 'glaze-hero__img',
                    alt: img_alt
                }}
              {%- else -%}
                <div class="glaze-hero__img glaze-hero__img--placeholder" aria-hidden="true">
                  {{ 'lifestyle-1' | placeholder_svg_tag }}
                </div>
              {%- endif -%}
            </div>
          </div>

          <div class="glaze-hero__panel glaze-grain">
            <div class="glaze-hero__panel-inner">
              {%- if block.settings.eyebrow != blank -%}
                <span class="glaze-eyebrow glaze-hero__eyebrow" data-reveal="mask">
                  {{ block.settings.eyebrow | escape }}
                </span>
              {%- endif -%}

              {%- if block.settings.heading != blank -%}
                <h2 class="glaze-display glaze-hero__heading" data-reveal="mask" style="--stagger-index: 1;">
                  {{ block.settings.heading | escape }}
                </h2>
              {%- endif -%}

              {%- if block.settings.body != blank -%}
                <p class="glaze-lede glaze-hero__body" data-reveal="fade" style="--stagger-index: 2;">
                  {{ block.settings.body }}
                </p>
              {%- endif -%}

              {%- if block.settings.button_label != blank -%}
                <a
                  class="glaze-hero__cta"
                  data-reveal="fade"
                  style="--stagger-index: 3;"
                  href="{{ block.settings.button_link | default: '#' }}"
                >
                  <span class="glaze-hero__cta-label">{{ block.settings.button_label | escape }}</span>
                  <span class="glaze-hero__cta-arrow" aria-hidden="true">
                    <svg viewBox="0 0 24 16" width="24" height="16" fill="none">
                      <path d="M1 8h21M16 1l7 7-7 7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </a>
              {%- endif -%}

              {%- if show_counter and section.blocks.size > 1 -%}
                <span class="glaze-hero__counter" aria-hidden="true">
                  <span class="glaze-hero__counter-current">{% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}</span>
                  <span class="glaze-hero__counter-sep">/</span>
                  <span class="glaze-hero__counter-total">{% if section.blocks.size < 10 %}0{% endif %}{{ section.blocks.size }}</span>
                </span>
              {%- endif -%}
            </div>
          </div>
        </article>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <nav class="glaze-hero__nav" aria-label="Slide controls">
      <ol class="glaze-hero__dots" role="tablist">
        {%- for block in section.blocks -%}
          {%- if block.type == 'slide' -%}
            <li role="presentation">
              <button
                type="button"
                class="glaze-hero__dot {% if forloop.first %}is-active{% endif %}"
                data-go-to="{{ forloop.index0 }}"
                role="tab"
                aria-label="Go to slide {{ forloop.index }}"
                {% if forloop.first %}aria-selected="true"{% else %}aria-selected="false"{% endif %}
              >
                <span class="glaze-hero__dot-num">{% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}</span>
                {%- if show_progress -%}
                  <span class="glaze-hero__progress" aria-hidden="true"><span class="glaze-hero__progress-bar"></span></span>
                {%- endif -%}
              </button>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ol>

      <button type="button" class="glaze-hero__pause" data-hero-toggle aria-label="Pause slideshow" aria-pressed="false">
        <svg class="glaze-hero__pause-icon glaze-hero__pause-icon--pause" viewBox="0 0 12 12" width="12" height="12" aria-hidden="true">
          <rect x="2" y="1" width="3" height="10" fill="currentColor"/><rect x="7" y="1" width="3" height="10" fill="currentColor"/>
        </svg>
        <svg class="glaze-hero__pause-icon glaze-hero__pause-icon--play" viewBox="0 0 12 12" width="12" height="12" aria-hidden="true">
          <path d="M2 1l9 5-9 5z" fill="currentColor"/>
        </svg>
      </button>
    </nav>

    <div class="visually-hidden" aria-live="polite" aria-atomic="true" data-hero-live></div>
  {%- endif -%}
</section>


{%- comment -%}
  This section ships no inline CSS or JS:
    - Styles live in assets/base.css under "S1. Hero slideshow"
    - Controller lives in assets/global.js as `Glaze.hero`, auto-initialising
      any element with [data-glaze-hero] (also re-runs on
      shopify:section:load so theme-editor reloads work).
  Per-instance values (height, autoplay speed, parallax strength) pass
  through inline `style="--hero-h-desk: …"` on the section element.
{%- endcomment -%}

{% schema %}
{
  "name": "Slideshow",
  "tag": "section",
  "class": "section-slideshow-glaze",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 520,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Desktop height",
      "default": 720
    },
    {
      "type": "range",
      "id": "height_mobile",
      "min": 420,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Mobile height",
      "default": 580
    },
    {
      "type": "range",
      "id": "parallax_strength",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Parallax strength",
      "info": "Vertical drift of the image while scrolling. Set 0 to disable.",
      "default": 40
    },
    {
      "type": "header",
      "content": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-advance slides",
      "default": true
    },
    {
      "type": "range",
      "id": "speed",
      "min": 4,
      "max": 12,
      "step": 1,
      "unit": "s",
      "label": "Seconds per slide",
      "default": 6
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "checkbox",
      "id": "show_progress",
      "label": "Show autoplay progress bars",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_counter",
      "label": "Show 01 / 03 counter on each slide",
      "default": true
    },
    {
      "type": "header",
      "content": "Accessibility"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Region label",
      "info": "Announced by screen readers when they enter the slideshow.",
      "default": "Featured stories"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Media"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video" }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Recommended: 2400 x 1600px. For video slides, used as the poster (first frame shown while video loads)."
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "MP4/WEBM, uploaded via Shopify Files. Plays muted, looped, autoplay. The image above is used as the poster frame."
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Edit 01"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Headline",
          "default": "Get the skin you want to feel"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Thoughtful, clean formulas built for everyday rituals — made to perform without performance."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop the edit"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "header",
          "content": "Layout"
        },
        {
          "type": "select",
          "id": "content_align",
          "label": "Content side",
          "options": [
            { "value": "right", "label": "Right" },
            { "value": "left",  "label": "Left" }
          ],
          "default": "right",
          "info": "Alternate left/right across slides for editorial rhythm."
        },
        {
          "type": "header",
          "content": "Colour theme"
        },
        {
          "type": "select",
          "id": "theme_preset",
          "label": "Surface theme",
          "options": [
            { "value": "cream",  "label": "Cream" },
            { "value": "blush",  "label": "Blush" },
            { "value": "sage",   "label": "Sage" },
            { "value": "ivory",  "label": "Ivory" },
            { "value": "ink",    "label": "Ink (dark)" },
            { "value": "custom", "label": "Custom" }
          ],
          "default": "cream"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Custom background",
          "info": "Used only when surface theme is set to Custom.",
          "default": "#FBE9E8"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Custom text",
          "info": "Used only when surface theme is set to Custom.",
          "default": "#1A1A1A"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial hero",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Edit 01",
            "heading": "Get the skin you want to feel",
            "body": "Thoughtful, clean formulas built for everyday rituals — made to perform without performance.",
            "button_label": "Shop the edit",
            "content_align": "right",
            "theme_preset": "cream"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Edit 02",
            "heading": "Quiet ingredients. Loud results.",
            "body": "Made with bio-active actives and the kind of restraint that lets your skin do the talking.",
            "button_label": "Discover the ritual",
            "content_align": "left",
            "theme_preset": "blush"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Edit 03",
            "heading": "Skin first. Always.",
            "body": "Dermatologist-approved formulas designed for sensitive routines, gentle on every skin type.",
            "button_label": "Browse all",
            "content_align": "right",
            "theme_preset": "sage"
          }
        }
      ]
    }
  ]
}
{% endschema %}
