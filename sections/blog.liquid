{%- liquid
  assign section_id = 'blog-' | append: section.id
  assign articles_per_page = section.settings.articles_per_page
  assign columns_desktop = section.settings.columns_desktop
  assign show_image = section.settings.show_image
  assign show_excerpt = section.settings.show_excerpt
  assign show_author = section.settings.show_author
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
-%}

<section
  id="{{ section_id }}"
  class="glaze-blog full-width"
  style="--bg: {{ bg_color }}; --fg: {{ text_color }}; --cols-d: {{ columns_desktop }};"
>
  <div class="glaze-blog__inner">
    <header class="glaze-blog__header">
      <h1 class="glaze-blog__title">{{ blog.title | escape }}</h1>
    </header>

    {%- paginate blog.articles by articles_per_page -%}
      {%- if blog.articles.size > 0 -%}
        <ul class="glaze-blog__grid" role="list">
          {%- for article in blog.articles -%}
            <li class="glaze-acard">
              <a class="glaze-acard__link" href="{{ article.url }}">
                {%- if show_image -%}
                  <div class="glaze-acard__media">
                    {%- if article.image -%}
                      {{ article.image | image_url: width: 800 | image_tag:
                          loading: 'lazy',
                          sizes: '(min-width: 1080px) 40vw, (min-width: 720px) 50vw, 95vw',
                          widths: '300, 450, 600, 800',
                          alt: article.image.alt | default: article.title | escape
                      }}
                    {%- else -%}
                      <span class="glaze-acard__placeholder" aria-hidden="true">{{ article.title | slice: 0 | upcase }}</span>
                    {%- endif -%}
                  </div>
                {%- endif -%}

                <div class="glaze-acard__body">
                  {%- assign date = article.published_at | time_tag: format: 'date' -%}
                  <p class="glaze-acard__meta">
                    {%- if show_author -%}
                      {{ 'blog.article_metadata_html' | t: date: date, author: article.author }}
                    {%- else -%}
                      {{ date }}
                    {%- endif -%}
                  </p>
                  <h2 class="glaze-acard__title">{{ article.title | escape }}</h2>
                  {%- if show_excerpt and article.excerpt != blank -%}
                    <p class="glaze-acard__excerpt">{{ article.excerpt | strip_html | truncatewords: 24 }}</p>
                  {%- endif -%}
                  <span class="glaze-acard__cta">{{ 'blog.read_more' | t }} →</span>
                </div>
              </a>
            </li>
          {%- endfor -%}
        </ul>

        {%- if paginate.pages > 1 -%}
          <nav class="glaze-blog__pagination" aria-label="{{ 'collection.pagination_aria' | t }}">
            {{- paginate | default_pagination -}}
          </nav>
        {%- endif -%}
      {%- else -%}
        <p class="glaze-blog__empty">{{ 'blog.empty' | t }}</p>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% stylesheet %}
  .glaze-blog {
    background: var(--bg, var(--g-cream));
    color: var(--fg, var(--g-ink));
    font-family: var(--g-body-font);
    padding: 64px 24px 96px;
  }
  .glaze-blog__inner { max-width: 1280px; margin: 0 auto; }
  .glaze-blog__header { text-align: center; margin-bottom: 40px; }
  .glaze-blog__title {
    font-family: var(--g-display-font);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 600;
    margin: 0;
  }
  .glaze-blog__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 720px) {
    .glaze-blog__grid { grid-template-columns: repeat(2, 1fr); gap: 28px; }
  }
  @media (min-width: 1080px) {
    .glaze-blog__grid { grid-template-columns: repeat(var(--cols-d, 3), 1fr); gap: 32px; }
  }
  .glaze-acard__link {
    color: var(--g-ink);
    text-decoration: none;
    display: grid;
    gap: 12px;
  }
  .glaze-acard__link:focus-visible { outline: 2px solid var(--g-rose); outline-offset: 4px; border-radius: var(--g-radius-md); }
  .glaze-acard__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--g-radius-md);
    background: var(--g-cream-warm);
    position: relative;
  }
  .glaze-acard__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .glaze-acard__link:hover .glaze-acard__media img { transform: scale(1.04); }
  .glaze-acard__placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: var(--g-display-font);
    font-size: 48px;
    font-weight: 700;
    color: var(--g-rose);
  }
  .glaze-acard__body { display: grid; gap: 6px; }
  .glaze-acard__meta {
    font-size: 12px;
    color: var(--g-muted);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .glaze-acard__title {
    font-family: var(--g-display-font);
    font-size: 20px;
    font-weight: 600;
    line-height: 1.25;
    margin: 0;
  }
  .glaze-acard__excerpt {
    color: var(--g-muted-strong);
    font-size: 14px;
    line-height: 1.55;
    margin: 0;
  }
  .glaze-acard__cta {
    color: var(--g-ink);
    font-size: 13px;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
    margin-top: 4px;
  }
  .glaze-blog__pagination {
    margin-top: 40px;
    display: flex;
    justify-content: center;
  }
  .glaze-blog__pagination .pagination {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    padding: 0;
    margin: 0;
  }
  .glaze-blog__pagination a,
  .glaze-blog__pagination span {
    min-width: var(--g-touch);
    min-height: var(--g-touch);
    padding: 0 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--g-radius-md);
    color: var(--g-ink);
    text-decoration: none;
    font-size: 14px;
  }
  .glaze-blog__pagination a:hover { background: var(--g-card-bg); }
  .glaze-blog__pagination .page.current { background: var(--g-ink); color: #fff; }
  .glaze-blog__empty {
    text-align: center;
    color: var(--g-muted);
    padding: 64px 24px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.blog",
  "tag": "section",
  "class": "section-blog",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "t:sections.blog.show_image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "t:sections.blog.show_excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "t:sections.blog.show_author",
      "default": true
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "min": 4,
      "max": 24,
      "step": 2,
      "label": "t:sections.blog.articles_per_page",
      "default": 8
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "t:sections.blog.columns_desktop",
      "default": 3
    },
    {
      "type": "header",
      "content": "t:sections.blog.colors_header"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:sections.blog.bg_color",
      "default": "#fbe9e8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.blog.text_color",
      "default": "#1a1a1a"
    }
  ]
}
{% endschema %}
