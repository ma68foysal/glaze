{%- liquid
  assign section_id = 'search-' | append: section.id
  assign products_per_page = section.settings.products_per_page
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
-%}

<section
  id="{{ section_id }}"
  class="glaze-search full-width"
  style="--bg: {{ bg_color }}; --fg: {{ text_color }};"
>
  <div class="glaze-search__inner">
    <header class="glaze-search__header">
      <h1 class="glaze-search__title">{{ 'search.title' | t }}</h1>

      <form action="{{ routes.search_url }}" method="get" role="search" class="glaze-search__form">
        <label for="{{ section_id }}-input" class="visually-hidden">{{ 'search.placeholder' | t }}</label>
        <input
          type="search"
          id="{{ section_id }}-input"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'search.placeholder' | t }}"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
          aria-label="{{ 'search.placeholder' | t }}"
        >
        <input type="hidden" name="type" value="article,page,product">
        <input type="hidden" name="options[prefix]" value="last">
        <button type="submit" class="glaze-search__submit">
          <span class="visually-hidden">{{ 'search.submit' | t }}</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
            <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </form>
    </header>

    {%- if search.performed -%}
      {%- if search.results_count == 0 -%}
        <p class="glaze-search__empty">{{ 'search.no_results_html' | t: terms: search.terms }}</p>
      {%- else -%}
        <p class="glaze-search__count">{{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}</p>

        {%- paginate search.results by products_per_page -%}
          <ul class="glaze-search__results" role="list">
            {%- for result in search.results -%}
              {%- assign featured_image = result.featured_image | default: result.image -%}
              <li class="glaze-search__result">
                <a class="glaze-search__result-link" href="{{ result.url }}">
                  <div class="glaze-search__result-media">
                    {%- if featured_image -%}
                      {{ featured_image | image_url: width: 400 | image_tag:
                          loading: 'lazy',
                          sizes: '120px',
                          widths: '120, 200, 300, 400',
                          alt: featured_image.alt | default: result.title | escape
                      }}
                    {%- else -%}
                      <span class="glaze-search__result-placeholder" aria-hidden="true">
                        {{ result.title | slice: 0 | upcase }}
                      </span>
                    {%- endif -%}
                  </div>
                  <div class="glaze-search__result-body">
                    <span class="glaze-search__result-type">{{ result.object_type | capitalize }}</span>
                    <span class="glaze-search__result-title">{{ result.title | escape }}</span>
                    {%- if result.price -%}
                      <span class="glaze-search__result-price">
                        {%- if result.price_varies -%}
                          {{ 'collection.from' | t }} {{ result.price_min | money }}
                        {%- else -%}
                          {{ result.price | money }}
                        {%- endif -%}
                      </span>
                    {%- elsif result.excerpt != blank -%}
                      <span class="glaze-search__result-excerpt">{{ result.excerpt | strip_html | truncatewords: 24 }}</span>
                    {%- endif -%}
                  </div>
                </a>
              </li>
            {%- endfor -%}
          </ul>

          {%- if paginate.pages > 1 -%}
            <nav class="glaze-search__pagination" aria-label="{{ 'collection.pagination_aria' | t }}">
              {{- paginate | default_pagination -}}
            </nav>
          {%- endif -%}
        {%- endpaginate -%}
      {%- endif -%}
    {%- else -%}
      <p class="glaze-search__prompt">{{ 'search.prompt' | t }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .glaze-search {
    background: var(--bg, var(--g-cream));
    color: var(--fg, var(--g-ink));
    font-family: var(--g-body-font);
    padding: 64px 24px 96px;
  }
  .glaze-search__inner {
    max-width: 960px;
    margin: 0 auto;
  }
  .glaze-search__header {
    text-align: center;
    margin-bottom: 32px;
  }
  .glaze-search__title {
    font-family: var(--g-display-font);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 600;
    margin: 0 0 24px;
  }
  .glaze-search__form {
    display: flex;
    align-items: center;
    gap: 0;
    max-width: 520px;
    margin: 0 auto;
    background: var(--g-card-bg);
    border: 1px solid var(--g-line);
    border-radius: var(--g-radius-pill);
    padding: 4px;
    min-height: var(--g-touch);
  }
  .glaze-search__form input[type="search"] {
    flex: 1;
    border: 0;
    background: transparent;
    font: inherit;
    color: var(--g-ink);
    padding: 8px 16px;
    min-height: 36px;
    border-radius: var(--g-radius-pill);
  }
  .glaze-search__form input[type="search"]::placeholder { color: var(--g-muted); }
  .glaze-search__form input[type="search"]:focus { outline: none; }
  .glaze-search__form:focus-within { outline: 2px solid var(--g-rose); outline-offset: 2px; }
  .glaze-search__submit {
    appearance: none;
    border: 0;
    background: var(--g-ink);
    color: #fff;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    cursor: pointer;
  }
  .glaze-search__submit:hover { filter: brightness(1.08); }
  .glaze-search__count,
  .glaze-search__empty,
  .glaze-search__prompt {
    text-align: center;
    margin: 0 0 24px;
    color: var(--g-muted-strong);
  }
  .glaze-search__results {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 12px;
  }
  .glaze-search__result-link {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 16px;
    padding: 12px;
    background: var(--g-card-bg);
    border-radius: var(--g-radius-md);
    color: var(--g-ink);
    text-decoration: none;
    align-items: center;
  }
  .glaze-search__result-link:hover { transform: translateY(-1px); }
  .glaze-search__result-link:focus-visible { outline: 2px solid var(--g-rose); outline-offset: 2px; }
  .glaze-search__result-media {
    aspect-ratio: 1 / 1;
    border-radius: var(--g-radius-md);
    overflow: hidden;
    background: var(--g-cream-warm);
    position: relative;
  }
  .glaze-search__result-media img { width: 100%; height: 100%; object-fit: cover; }
  .glaze-search__result-placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: var(--g-display-font);
    font-size: 32px;
    font-weight: 700;
    color: var(--g-rose);
  }
  .glaze-search__result-body {
    display: grid;
    gap: 4px;
  }
  .glaze-search__result-type {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--g-muted);
  }
  .glaze-search__result-title {
    font-weight: 600;
    font-size: 15px;
    line-height: 1.3;
  }
  .glaze-search__result-excerpt {
    font-size: 13px;
    color: var(--g-muted-strong);
    line-height: 1.45;
  }
  .glaze-search__result-price {
    font-size: 14px;
    font-weight: 600;
    color: var(--g-ink);
  }
  .glaze-search__pagination {
    margin-top: 32px;
    display: flex;
    justify-content: center;
  }
  /* .pagination internals + .visually-hidden live in assets/base.css */
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "tag": "section",
  "class": "section-search",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "label": "t:sections.search.products_per_page",
      "default": 20
    },
    {
      "type": "header",
      "content": "t:sections.search.colors_header"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:sections.search.bg_color",
      "default": "#fbe9e8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.search.text_color",
      "default": "#1a1a1a"
    }
  ]
}
{% endschema %}
