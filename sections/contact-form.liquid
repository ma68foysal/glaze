{%- liquid
  assign section_id = 'contact-form-' | append: section.id
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign submit_label = section.settings.submit_label
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
  assign field_bg = section.settings.field_bg
  assign field_border = section.settings.field_border
  assign accent_color = section.settings.accent_color
  assign accent_text_color = section.settings.accent_text_color
-%}

<section
  id="{{ section_id }}"
  class="contact-form-section"
  aria-labelledby="{{ section_id }}-heading"
  style="
    --bg: {{ bg_color }};
    --fg: {{ text_color }};
    --field-bg: {{ field_bg }};
    --field-border: {{ field_border }};
    --accent: {{ accent_color }};
    --accent-fg: {{ accent_text_color }};
    --pad-top: {{ section.settings.padding_top }}px;
    --pad-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="contact-form-inner">
    {%- if heading != blank -%}
      <h2 id="{{ section_id }}-heading" class="contact-form-heading">{{ heading | escape }}</h2>
    {%- else -%}
      <h2 id="{{ section_id }}-heading" class="visually-hidden">{{ 'contact.title' | t }}</h2>
    {%- endif -%}

    {%- if subheading != blank -%}
      <p class="contact-form-subheading">{{ subheading | escape }}</p>
    {%- endif -%}

    {%- form 'contact', id: section_id | append: '-form', class: 'contact-form' -%}
      {%- if form.posted_successfully? -%}
        <p class="contact-form-success" role="status">{{ 'contact.success' | t }}</p>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="contact-form-errors" role="alert" tabindex="-1">
          <p>{{ 'contact.error_heading' | t }}</p>
          <ul>
            {%- for field in form.errors -%}
              <li>
                <a href="#contact-{{ section.id }}-{{ field }}">
                  {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div class="contact-form-row">
        <div class="contact-form-field">
          <label for="contact-{{ section.id }}-name">{{ 'contact.name' | t }}</label>
          <input
            type="text"
            id="contact-{{ section.id }}-name"
            name="contact[{{ 'contact.name' | t }}]"
            value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
            autocomplete="name"
          >
        </div>

        <div class="contact-form-field">
          <label for="contact-{{ section.id }}-email">{{ 'contact.email' | t }} <span aria-hidden="true">*</span></label>
          <input
            type="email"
            id="contact-{{ section.id }}-email"
            name="contact[email]"
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            required
            aria-required="true"
          >
        </div>
      </div>

      <div class="contact-form-field">
        <label for="contact-{{ section.id }}-phone">{{ 'contact.phone' | t }}</label>
        <input
          type="tel"
          id="contact-{{ section.id }}-phone"
          name="contact[{{ 'contact.phone' | t }}]"
          value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
          autocomplete="tel"
          pattern="[0-9\-+\s()]*"
        >
      </div>

      <div class="contact-form-field">
        <label for="contact-{{ section.id }}-body">{{ 'contact.message' | t }} <span aria-hidden="true">*</span></label>
        <textarea
          id="contact-{{ section.id }}-body"
          name="contact[body]"
          rows="6"
          required
          aria-required="true"
        >{% if form.body %}{{ form.body }}{% endif %}</textarea>
      </div>

      <button type="submit" class="contact-form-submit">{{ submit_label | escape }}</button>
    {%- endform -%}
  </div>
</section>

{% stylesheet %}
  .contact-form-section {
    background: var(--bg, #fbe9e8);
    color: var(--fg, #1a1a1a);
    padding: var(--pad-top, 72px) 24px var(--pad-bottom, 72px);
    font-family: var(--g-body-font, system-ui, sans-serif);
  }
  .contact-form-inner {
    max-width: 640px;
    margin: 0 auto;
  }
  .contact-form-heading {
    font-family: var(--g-display-font, serif);
    font-size: clamp(28px, 3vw, 40px);
    line-height: 1.15;
    margin: 0 0 12px;
    color: var(--fg);
    text-align: center;
  }
  .contact-form-subheading {
    font-size: 15px;
    line-height: 1.55;
    margin: 0 0 32px;
    color: var(--fg);
    opacity: 0.78;
    text-align: center;
  }
  .contact-form {
    display: grid;
    gap: 16px;
  }
  .contact-form-row {
    display: grid;
    gap: 16px;
    grid-template-columns: 1fr 1fr;
  }
  @media (max-width: 600px) {
    .contact-form-row { grid-template-columns: 1fr; }
  }
  .contact-form-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .contact-form-field label {
    font-size: 13px;
    font-weight: 500;
    color: var(--fg);
  }
  .contact-form-field input,
  .contact-form-field textarea {
    font: inherit;
    color: var(--fg);
    background: var(--field-bg, #ffffff);
    border: 1px solid var(--field-border, #00000014);
    border-radius: 10px;
    padding: 12px 14px;
    min-height: 44px;
    width: 100%;
    box-sizing: border-box;
  }
  .contact-form-field textarea {
    resize: vertical;
    min-height: 132px;
    font-family: inherit;
  }
  .contact-form-field input:focus,
  .contact-form-field textarea:focus {
    outline: 2px solid var(--accent, #e8a5a0);
    outline-offset: 2px;
  }
  .contact-form-submit {
    font: inherit;
    font-weight: 600;
    color: var(--accent-fg, #ffffff);
    background: var(--accent, #1a1a1a);
    border: 0;
    border-radius: 100px;
    padding: 14px 28px;
    min-height: 44px;
    cursor: pointer;
    justify-self: start;
  }
  .contact-form-submit:hover { filter: brightness(1.06); }
  .contact-form-submit:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .contact-form-success {
    background: #e9f7ec;
    color: #1d6b2e;
    border-radius: 10px;
    padding: 12px 14px;
    margin: 0 0 12px;
  }
  .contact-form-errors {
    background: #fbe9e9;
    color: #8a1a1a;
    border-radius: 10px;
    padding: 12px 14px;
    margin: 0 0 12px;
  }
  .contact-form-errors ul { margin: 6px 0 0 18px; }
  .contact-form-errors a { color: inherit; }
  /* .visually-hidden lives in assets/base.css */
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.contact_form.name",
  "tag": "section",
  "class": "section-contact-form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.contact_form.heading_label",
      "default": "Get in touch"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.contact_form.subheading_label",
      "default": "We typically reply within one business day."
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "t:sections.contact_form.submit_label",
      "default": "Send message"
    },
    {
      "type": "header",
      "content": "t:sections.contact_form.colors_header"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:sections.contact_form.bg_color",
      "default": "#fbe9e8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.contact_form.text_color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "field_bg",
      "label": "t:sections.contact_form.field_bg",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "field_border",
      "label": "t:sections.contact_form.field_border",
      "default": "#00000014"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "t:sections.contact_form.accent_color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "accent_text_color",
      "label": "t:sections.contact_form.accent_text_color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "t:sections.contact_form.spacing_header"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.contact_form.padding_top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.contact_form.padding_bottom",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact_form.name"
    }
  ]
}
{% endschema %}
