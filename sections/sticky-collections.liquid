{%- liquid
  assign section_id = 'glaze-stc-' | append: section.id
-%}

<style>
  /* ============================================================
     Sticky Collections Glaze — scoped styles (stc- prefix)
     ============================================================ */

  #{{ section_id }} {
    --stc-bg: {{ section.settings.bg_color }};
    --stc-fg: {{ section.settings.text_color }};

    --stc-image-radius: {{ section.settings.image_radius }}px;
    --stc-eyebrow-c: {{ section.settings.eyebrow_color }};
    --stc-eyebrow-s: {{ section.settings.eyebrow_size }}px;
    --stc-image-title-c: {{ section.settings.image_title_color }};
    --stc-image-title-s: {{ section.settings.image_title_size }}px;
    --stc-image-title-w: {{ section.settings.image_title_weight }};
    --stc-image-btn-bg: {{ section.settings.image_btn_bg }};
    --stc-image-btn-fg: {{ section.settings.image_btn_fg }};

    --stc-coll-title-c: {{ section.settings.coll_title_color }};
    --stc-coll-title-s: {{ section.settings.coll_title_size }}px;
    --stc-coll-title-w: {{ section.settings.coll_title_weight }};

    --stc-nav-bg: {{ section.settings.nav_bg }};
    --stc-nav-fg: {{ section.settings.nav_fg }};
    --stc-nav-hover-bg: {{ section.settings.nav_hover_bg }};
    --stc-nav-hover-fg: {{ section.settings.nav_hover_fg }};

    --stc-card-bg: {{ section.settings.card_bg }};
    --stc-card-radius: {{ section.settings.card_radius }}px;

    --stc-title-color: {{ section.settings.card_title_color }};
    --stc-title-size: {{ section.settings.card_title_size }}px;
    --stc-type-color: {{ section.settings.type_color }};
    --stc-type-size: {{ section.settings.type_size }}px;
    --stc-price-color: {{ section.settings.price_color }};
    --stc-price-size: {{ section.settings.price_size }}px;
    --stc-compare-color: {{ section.settings.compare_color }};

    --stc-sale-bg: {{ section.settings.sale_bg }};
    --stc-sale-fg: {{ section.settings.sale_fg }};
    --stc-new-bg: {{ section.settings.new_bg }};
    --stc-new-fg: {{ section.settings.new_fg }};
    --stc-hot-bg: {{ section.settings.hot_bg }};
    --stc-hot-fg: {{ section.settings.hot_fg }};
    --stc-badge-size: {{ section.settings.badge_size }}px;

    --stc-btn-bg: {{ section.settings.btn_bg }};
    --stc-btn-fg: {{ section.settings.btn_fg }};
    --stc-btn-hover-bg: {{ section.settings.btn_hover_bg }};
    --stc-btn-hover-fg: {{ section.settings.btn_hover_fg }};

    --stc-pad-top: {{ section.settings.padding_top }}px;
    --stc-pad-bottom: {{ section.settings.padding_bottom }}px;
    --stc-gap: {{ section.settings.coll_gap }}px;
    --stc-sticky-top: {{ section.settings.sticky_offset }}px;

    display: block;
    background: var(--stc-bg);
    color: var(--stc-fg);
    padding: var(--stc-pad-top) 0 var(--stc-pad-bottom);
    /* overflow-x: clip prevents horizontal scroll WITHOUT breaking position: sticky
       (unlike overflow: hidden which creates a scroll container) */
    overflow-x: clip;
  }

  #{{ section_id }} .stc-wrap,
  #{{ section_id }} .stc-coll {
    max-width: 100%;
  }

  /* Slider viewport uses overflow: hidden directly — safe because it's a
     descendant of .stc-right (sibling of the sticky .stc-left), not an
     ancestor of the sticky element, so it doesn't break sticky positioning. */
  #{{ section_id }} .stc-coll-viewport {
    max-width: 100%;
    overflow: hidden;
  }

  #{{ section_id }} *,
  #{{ section_id }} *::before,
  #{{ section_id }} *::after { box-sizing: border-box; }

  .stc-wrap {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* -------- Section header (title + desc + button) -------- */
  .stc-head {
    text-align: center;
    margin-bottom: 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  .stc-head[data-align="left"] { text-align: left; align-items: flex-start; }
  .stc-head[data-align="right"] { text-align: right; align-items: flex-end; }

  .stc-head-title {
    margin: 0;
    color: {{ section.settings.head_title_color }};
    font-size: {{ section.settings.head_title_size }}px;
    font-weight: {{ section.settings.head_title_weight }};
    line-height: 1.15;
    letter-spacing: -0.01em;
    max-width: 26ch;
  }

  .stc-head-desc {
    margin: 0;
    color: {{ section.settings.head_desc_color }};
    font-size: {{ section.settings.head_desc_size }}px;
    line-height: 1.55;
    max-width: 44ch;
  }

  .stc-head-link {
    display: inline-block;
    color: {{ section.settings.head_link_color }};
    font-size: {{ section.settings.head_link_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1.5px solid currentColor;
    padding-bottom: 2px;
    transition: opacity 0.2s ease;
  }

  .stc-head-link:hover { opacity: 0.7; }

  /* -------- Grid: sticky left, stacked right -------- */
  .stc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }

  /* -------- Left: sticky image card -------- */
  .stc-left {
    position: sticky;
    top: var(--stc-sticky-top);
    align-self: start;
  }

  .stc-image-card {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--stc-image-radius);
    overflow: hidden;
    background: #eee;
  }

  .stc-image-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .stc-image-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40px;
    text-align: center;
    background: linear-gradient(to bottom, rgba(0,0,0,0.15), rgba(0,0,0,0.3));
    gap: 14px;
  }

  .stc-image-card[data-pos="top"] .stc-image-overlay { justify-content: flex-start; }
  .stc-image-card[data-pos="middle"] .stc-image-overlay { justify-content: center; }
  .stc-image-card[data-pos="bottom"] .stc-image-overlay { justify-content: flex-end; }

  .stc-image-eyebrow {
    margin: 0;
    color: var(--stc-eyebrow-c);
    font-size: var(--stc-eyebrow-s);
    font-weight: 500;
    letter-spacing: 0.03em;
  }

  .stc-image-title {
    margin: 0 0 16px;
    color: var(--stc-image-title-c);
    font-size: var(--stc-image-title-s);
    font-weight: var(--stc-image-title-w);
    line-height: 1.15;
    letter-spacing: -0.01em;
    max-width: 14ch;
  }

  .stc-image-btn {
    display: inline-flex;
    align-items: center;
    padding: 14px 32px;
    border-radius: 999px;
    background: var(--stc-image-btn-bg);
    color: var(--stc-image-btn-fg);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .stc-image-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.15);
  }

  /* -------- Right: collection blocks -------- */
  .stc-right {
    display: flex;
    flex-direction: column;
    gap: var(--stc-gap);
  }

  .stc-coll {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .stc-coll-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .stc-coll-title {
    margin: 0;
    color: var(--stc-coll-title-c);
    font-size: var(--stc-coll-title-s);
    font-weight: var(--stc-coll-title-w);
    letter-spacing: -0.01em;
  }

  .stc-coll-nav {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .stc-coll-count {
    font-size: 14px;
    color: var(--stc-coll-title-c);
    min-width: 38px;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }

  .stc-nav-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.12);
    background: var(--stc-nav-bg);
    color: var(--stc-nav-fg);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }

  .stc-nav-btn:hover:not([disabled]) {
    background: var(--stc-nav-hover-bg);
    color: var(--stc-nav-hover-fg);
    border-color: var(--stc-nav-hover-bg);
  }

  .stc-nav-btn[disabled] { opacity: 0.35; cursor: default; }
  .stc-nav-btn svg { width: 14px; height: 14px; }

  /* Slider viewport & track */
  .stc-coll-viewport {
    overflow: hidden;
    width: 100%;
  }

  .stc-coll-track {
    display: flex;
    gap: 16px;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  /* -------- Card (match Featured Product Glaze) -------- */
  .stc-card {
    flex: 0 0 calc((100% - 16px) / 2);
    position: relative;
    background: var(--stc-card-bg);
    border-radius: var(--stc-card-radius);
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: transform 0.35s ease;
  }

  .stc-card-media {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    isolation: isolate;
  }

  .stc-card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transition: opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .stc-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .stc-card-img.is-secondary { opacity: 0; }

  .stc-card:hover .stc-card-img.is-primary { opacity: 0; }
  .stc-card:hover .stc-card-img.is-secondary { opacity: 1; transform: scale(1.02); }

  /* Badges */
  .stc-card-badges {
    position: absolute;
    top: 10px;
    left: 10px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    z-index: 3;
  }

  .stc-badge {
    padding: 4px 8px;
    border-radius: 4px;
    font-size: var(--stc-badge-size);
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.02em;
  }

  .stc-badge--sale { background: var(--stc-sale-bg); color: var(--stc-sale-fg); }
  .stc-badge--new { background: var(--stc-new-bg); color: var(--stc-new-fg); }
  .stc-badge--hot { background: var(--stc-hot-bg); color: var(--stc-hot-fg); }

  /* Search icon (hover reveal on desktop) */
  .stc-card-search {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 32px;
    height: 32px;
    border: 0;
    border-radius: 50%;
    background: #fff;
    color: #111;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 3;
    opacity: 0;
    transform: translateY(-4px);
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease,
                background 0.3s ease, color 0.3s ease;
  }

  .stc-card:hover .stc-card-search {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .stc-card-search:hover { background: #111; color: #fff; }
  .stc-card-search svg { width: 13px; height: 13px; }

  /* Hover CTA with glass sweep */
  .stc-card-cta {
    position: absolute;
    left: 10px;
    right: 10px;
    bottom: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 16px;
    background: var(--stc-btn-bg);
    color: var(--stc-btn-fg);
    border: 0;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    opacity: 0;
    transform: translateY(10px);
    overflow: hidden;
    z-index: 3;
    transition: opacity 0.35s ease, transform 0.35s ease,
                background 0.4s ease, color 0.4s ease;
    text-decoration: none;
  }

  .stc-card:hover .stc-card-cta { opacity: 1; transform: translateY(0); }
  .stc-card-cta:hover { background: var(--stc-btn-hover-bg); color: var(--stc-btn-hover-fg); }

  .stc-card-cta::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(120deg, transparent 0%, rgba(255,255,255,0) 30%, rgba(255,255,255,0.55) 50%, rgba(255,255,255,0) 70%, transparent 100%);
    pointer-events: none;
    transition: left 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .stc-card-cta:hover::before { left: 140%; }
  .stc-card-cta:not(:hover)::before { transition: left 0.6s cubic-bezier(0.4, 0, 0.2, 1); }
  .stc-card-cta-label { position: relative; z-index: 1; }
  .stc-card-cta-icon { position: relative; z-index: 1; display: none; }
  .stc-card-cta-icon svg { width: 16px; height: 16px; }

  /* Card body */
  .stc-card-body { padding: 12px 4px 0; }
  .stc-card-type { color: var(--stc-type-color); font-size: var(--stc-type-size); margin: 0 0 4px; letter-spacing: 0.02em; }
  .stc-card-title { color: var(--stc-title-color); font-size: var(--stc-title-size); font-weight: 600; margin: 0 0 6px; line-height: 1.3; }
  .stc-card-price { color: var(--stc-price-color); font-size: var(--stc-price-size); font-weight: 600; margin: 0; }
  .stc-card-price-compare { color: var(--stc-compare-color); text-decoration: line-through; font-weight: 400; margin-left: 6px; }

  /* -------- Modal (right side) -------- */
  .stc-modal-overlay {
    position: fixed; inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 150;
    opacity: 0; visibility: hidden;
    transition: opacity 0.35s ease, visibility 0.35s ease;
  }
  .stc-modal-overlay.is-open { opacity: 1; visibility: visible; }

  .stc-modal {
    position: fixed;
    top: 0; right: 0; bottom: 0;
    width: 100%;
    max-width: 560px;
    background: #fff;
    color: #111;
    z-index: 160;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    overflow: hidden;
  }
  .stc-modal.is-open { transform: translateX(0); }

  .stc-modal-close {
    position: absolute; top: 16px; right: 16px;
    width: 40px; height: 40px; border: 0; border-radius: 50%;
    background: #fff; color: #111;
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer; z-index: 5;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }
  .stc-modal-close:hover { background: #111; color: #fff; transform: rotate(90deg); }
  .stc-modal-close svg { width: 14px; height: 14px; }

  .stc-modal-inner { flex: 1; overflow-y: auto; padding: 24px 32px 32px; }

  .stc-mslider { position: relative; margin-bottom: 16px; }
  .stc-mslider-viewport { width: 100%; aspect-ratio: 1/1; background: #f5f5f5; border-radius: 14px; overflow: hidden; position: relative; }
  .stc-mslider-track { display: flex; height: 100%; transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1); }
  .stc-mslide { flex: 0 0 100%; height: 100%; padding: 10%; box-sizing: border-box; }
  .stc-mslide img { width: 100%; height: 100%; object-fit: contain; display: block; }

  .stc-mslider-nav { display: flex; align-items: center; justify-content: center; gap: 16px; margin-top: 10px; color: #555; font-size: 13px; }
  .stc-mslider-btn { width: 28px; height: 28px; border-radius: 50%; border: 0; background: transparent; color: #111; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; }
  .stc-mslider-btn:hover { background: rgba(0,0,0,0.06); }
  .stc-mslider-btn[disabled] { opacity: 0.35; cursor: default; }
  .stc-mslider-btn svg { width: 14px; height: 14px; }
  .stc-mslider-count { min-width: 32px; text-align: center; font-variant-numeric: tabular-nums; }

  .stc-modal-title { font-size: 28px; font-weight: 600; margin: 18px 0 10px; line-height: 1.2; }
  .stc-modal-price { font-size: 20px; font-weight: 600; margin: 0 0 6px; }
  .stc-modal-price-compare { font-size: 15px; color: #888; text-decoration: line-through; margin-left: 8px; font-weight: 400; }
  .stc-modal-desc { font-size: 14px; line-height: 1.6; color: #333; margin: 8px 0 22px; }

  .stc-modal-opt { margin-bottom: 18px; }
  .stc-modal-opt-label { font-size: 14px; font-weight: 600; margin: 0 0 10px; }
  .stc-modal-opt-list { display: flex; flex-wrap: wrap; gap: 8px; }
  .stc-modal-opt-btn { padding: 10px 18px; border: 1px solid #ddd; border-radius: 999px; background: #fff; font-size: 14px; font-weight: 500; color: #111; cursor: pointer; transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease; }
  .stc-modal-opt-btn:hover { border-color: #111; }
  .stc-modal-opt-btn.is-active { background: #111; color: #fff; border-color: #111; }

  .stc-modal-actions { display: flex; gap: 10px; align-items: center; margin-top: 20px; }
  .stc-modal-qty { display: inline-flex; align-items: center; border: 1px solid #ddd; border-radius: 999px; overflow: hidden; height: 48px; }
  .stc-modal-qty-btn { width: 40px; height: 100%; border: 0; background: transparent; font-size: 18px; cursor: pointer; color: #111; }
  .stc-modal-qty-btn:hover { background: #f5f5f5; }
  .stc-modal-qty-input { width: 40px; border: 0; text-align: center; font-size: 15px; font-weight: 500; background: transparent; -moz-appearance: textfield; appearance: textfield; }
  .stc-modal-qty-input::-webkit-outer-spin-button, .stc-modal-qty-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  .stc-modal-atc { flex: 1; height: 48px; border: 1px solid #ddd; border-radius: 999px; background: #f1f1f1; color: #111; font-size: 14px; font-weight: 600; cursor: pointer; transition: background 0.2s ease, color 0.2s ease; }
  .stc-modal-atc:hover:not([disabled]) { background: #111; color: #fff; }
  .stc-modal-atc[disabled] { opacity: 0.5; cursor: not-allowed; }

  .stc-modal-buy { width: 100%; margin-top: 10px; height: 52px; border: 0; border-radius: 999px; background: #111; color: #fff; font-size: 15px; font-weight: 600; cursor: pointer; transition: background 0.2s ease; }
  .stc-modal-buy:hover { background: #222; }

  .stc-modal-full { display: flex; justify-content: space-between; align-items: center; margin-top: 24px; padding-top: 20px; border-top: 1px solid #eee; color: #111; font-size: 15px; text-decoration: none; font-weight: 500; }
  .stc-modal-full:hover { text-decoration: underline; }

  /* -------- Responsive -------- */
  @media screen and (max-width: 989px) {
    .stc-grid { grid-template-columns: 1fr; gap: 20px; }
    .stc-left { position: static; top: auto; width: 100%; }
    /* Landscape aspect so the image is compact, not dominating viewport */
    .stc-image-card { aspect-ratio: 4 / 3; width: 100%; max-width: 100%; margin: 0; }
    .stc-wrap { padding: 0 20px; }
    .stc-head { margin-bottom: 24px; }
    .stc-head-title { font-size: 28px; }
  }

  @media screen and (max-width: 749px) {
    .stc-wrap { padding: 0 16px; }

    /* Very compact image on mobile — short landscape so arrows + cards visible below */
    .stc-image-card {
      aspect-ratio: 4 / 3;
      max-width: 60%;
      margin: 0;
    }

    .stc-coll-head {
      max-width: 60%;
      margin: 0;
      width: 100%;
    }
    .stc-image-overlay { padding: 20px 18px; gap: 8px; }
    .stc-image-title { font-size: 22px; margin-bottom: 4px; }
    .stc-image-btn { padding: 10px 20px; font-size: 13px; }
    .stc-image-eyebrow { font-size: 12px; }

    .stc-coll-title { font-size: 20px; }
    .stc-coll-count { font-size: 13px; min-width: 32px; }
    .stc-nav-btn { width: 34px; height: 34px; opacity: 1; }
    .stc-nav-btn[disabled] { opacity: 0.5; }
    .stc-nav-btn svg { width: 12px; height: 12px; }
    .stc-head-title { font-size: 24px; }
    .stc-head-desc { font-size: 14px; }

    /* 2 cards per view — small cards, matches the reference layout */
    .stc-coll-track { gap: 12px; }
    .stc-card {
      flex: 0 0 calc((100% - 12px) / 2);
    }
    .stc-card-badges { top: 8px; left: 8px; }
    .stc-card-cta {
      left: auto; right: 10px; bottom: 10px;
      width: 36px; height: 36px; padding: 0; border-radius: 50%;
      opacity: 1; transform: none;
      background: var(--stc-btn-bg); color: var(--stc-btn-fg);
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .stc-card-cta::before { display: none; }
    .stc-card-cta-label { display: none; }
    .stc-card-cta-icon { display: inline-flex; align-items: center; justify-content: center; }
    .stc-card-search { display: none; }

    .stc-modal { max-width: 100%; }
    .stc-modal-inner { padding: 20px 18px 24px; }
    .stc-modal-title { font-size: 22px; }
    .stc-modal-actions { flex-wrap: wrap; gap: 8px; }
    .stc-modal-atc { flex: 1 1 auto; min-width: 0; height: 44px; font-size: 13px; }
    .stc-modal-qty { height: 44px; }
  }
</style>

<div id="{{ section_id }}" class="glaze-stc" data-glaze-stc>
  <div class="stc-wrap">

    {%- if section.settings.head_title != blank or section.settings.head_desc != blank or section.settings.head_link_label != blank -%}
      <div class="stc-head" data-align="{{ section.settings.head_align }}">
        {%- if section.settings.head_title != blank -%}
          <h2 class="stc-head-title">{{ section.settings.head_title }}</h2>
        {%- endif -%}
        {%- if section.settings.head_desc != blank -%}
          <p class="stc-head-desc">{{ section.settings.head_desc }}</p>
        {%- endif -%}
        {%- if section.settings.head_link_label != blank -%}
          <a href="{{ section.settings.head_link_url | default: '#' }}" class="stc-head-link">{{ section.settings.head_link_label }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="stc-grid">

      <div class="stc-left">
        <div class="stc-image-card" data-pos="{{ section.settings.image_content_position }}">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: section.settings.image_title, widths: '400,600,800,1000,1200' }}
          {%- endif -%}
          {%- if section.settings.eyebrow != blank or section.settings.image_title != blank or section.settings.btn_label != blank -%}
            <div class="stc-image-overlay">
              {%- if section.settings.eyebrow != blank -%}
                <p class="stc-image-eyebrow">{{ section.settings.eyebrow }}</p>
              {%- endif -%}
              {%- if section.settings.image_title != blank -%}
                <h2 class="stc-image-title">{{ section.settings.image_title }}</h2>
              {%- endif -%}
              {%- if section.settings.btn_label != blank -%}
                <a href="{{ section.settings.btn_link | default: '#' }}" class="stc-image-btn">{{ section.settings.btn_label }}</a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>

      <div class="stc-right">
        {%- for block in section.blocks -%}
          {%- assign coll = block.settings.collection -%}
          {%- assign title = block.settings.title_override | default: coll.title | default: 'Collection' -%}
          {%- assign per = block.settings.products_count -%}

          <div class="stc-coll" data-stc-coll="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            <div class="stc-coll-head">
              <h3 class="stc-coll-title">{{ title }}</h3>
              <div class="stc-coll-nav">
                <button type="button" class="stc-nav-btn" data-stc-prev aria-label="Previous">
                  <svg viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <span class="stc-coll-count"><span data-stc-current>1</span>/<span data-stc-total>1</span></span>
                <button type="button" class="stc-nav-btn" data-stc-next aria-label="Next">
                  <svg viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
              </div>
            </div>

            <div class="stc-coll-viewport">
              <div class="stc-coll-track" data-stc-track>
                {%- if coll != blank -%}
                  {%- for product in coll.products limit: per -%}
                    {%- assign primary = product.featured_image -%}
                    {%- assign secondary = nil -%}
                    {%- if product.images.size > 1 -%}{%- assign secondary = product.images[1] -%}{%- endif -%}

                    {%- assign is_sale = false -%}
                    {%- if product.compare_at_price > product.price -%}
                      {%- assign is_sale = true -%}
                      {%- assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
                    {%- endif -%}
                    {%- assign is_new = false -%}
                    {%- assign is_hot = false -%}
                    {%- if product.tags contains 'new' or product.tags contains 'New' -%}{%- assign is_new = true -%}{%- endif -%}
                    {%- if product.tags contains 'hot' or product.tags contains 'Selling fast' or product.tags contains 'selling-fast' -%}{%- assign is_hot = true -%}{%- endif -%}

                    {%- assign has_variants = false -%}
                    {%- if product.variants.size > 1 or product.has_only_default_variant == false -%}{%- assign has_variants = true -%}{%- endif -%}

                    <div class="stc-card" data-product-handle="{{ product.handle }}" data-product-url="{{ product.url }}">
                      <div class="stc-card-media">
                        <a href="{{ product.url }}" class="stc-card-img is-primary" aria-label="{{ product.title }}">
                          {%- if primary -%}{{ primary | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title, widths: '300,400,600,800' }}{%- endif -%}
                        </a>
                        {%- if secondary -%}
                          <a href="{{ product.url }}" class="stc-card-img is-secondary" tabindex="-1" aria-hidden="true">
                            {{ secondary | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title, widths: '300,400,600,800' }}
                          </a>
                        {%- endif -%}

                        <div class="stc-card-badges">
                          {%- if is_sale -%}<span class="stc-badge stc-badge--sale">-{{ discount }}%</span>{%- endif -%}
                          {%- if is_new -%}<span class="stc-badge stc-badge--new">New</span>{%- endif -%}
                          {%- if is_hot -%}<span class="stc-badge stc-badge--hot">Popular</span>{%- endif -%}
                        </div>

                        <button type="button" class="stc-card-search" data-stc-quickview="{{ product.handle }}" aria-label="Quick view">
                          <svg viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"/><path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                        </button>

                        {%- if has_variants -%}
                          <button type="button" class="stc-card-cta" data-stc-quickview="{{ product.handle }}">
                            <span class="stc-card-cta-label">{{ section.settings.choose_options_label | default: 'Choose Options' }}</span>
                            <span class="stc-card-cta-icon" aria-hidden="true">
                              <svg viewBox="0 0 24 24" fill="none"><path d="M5 8h14l-1.2 11a2 2 0 0 1-2 1.8H8.2a2 2 0 0 1-2-1.8L5 8zM9 8a3 3 0 0 1 6 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </span>
                          </button>
                        {%- else -%}
                          <button type="button" class="stc-card-cta" data-stc-atc="{{ product.variants.first.id }}" {% if product.available == false %}disabled{% endif %}>
                            <span class="stc-card-cta-label">{%- if product.available -%}{{ section.settings.atc_label | default: 'Add To Cart' }}{%- else -%}Sold out{%- endif -%}</span>
                            <span class="stc-card-cta-icon" aria-hidden="true">
                              <svg viewBox="0 0 24 24" fill="none"><path d="M5 8h14l-1.2 11a2 2 0 0 1-2 1.8H8.2a2 2 0 0 1-2-1.8L5 8zM9 8a3 3 0 0 1 6 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </span>
                          </button>
                        {%- endif -%}
                      </div>

                      <a href="{{ product.url }}" class="stc-card-body" style="text-decoration:none; color:inherit;">
                        {%- if product.type != blank -%}<p class="stc-card-type">{{ product.type }}</p>{%- endif -%}
                        <p class="stc-card-title">{{ product.title }}</p>
                        <p class="stc-card-price">
                          {%- if product.price_varies -%}From {% endif -%}{{ product.price | money }}
                          {%- if is_sale -%}<span class="stc-card-price-compare">{{ product.compare_at_price | money }}</span>{%- endif -%}
                        </p>
                      </a>

                      <script type="application/json" data-stc-product="{{ product.handle }}">
                        {{ product | json }}
                      </script>
                    </div>
                  {%- endfor -%}
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>

  {%- comment -%} Shared quick-view modal {%- endcomment -%}
  <div class="stc-modal-overlay" data-stc-modal-close></div>
  <aside class="stc-modal" aria-hidden="true" role="dialog" aria-modal="true" data-stc-modal>
    <button type="button" class="stc-modal-close" data-stc-modal-close aria-label="Close">
      <svg viewBox="0 0 14 14" fill="none"><path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
    </button>
    <div class="stc-modal-inner" data-stc-modal-body></div>
  </aside>
</div>

<script>
  (function () {
    var root = document.getElementById('{{ section_id }}');
    if (!root) return;
    var moneyFormat = {{ shop.money_format | json }};

    function formatMoney(cents) {
      var amount = (cents / 100).toFixed(2);
      var parts = amount.split('.');
      var intPart = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      var formatted = intPart + '.' + parts[1];
      return moneyFormat
        .replace(/\{\{\s*amount\s*\}\}/g, formatted)
        .replace(/\{\{\s*amount_no_decimals\s*\}\}/g, intPart)
        .replace(/\{\{\s*amount_with_comma_separator\s*\}\}/g, formatted.replace('.', ','))
        .replace(/\{\{\s*amount_no_decimals_with_comma_separator\s*\}\}/g, intPart);
    }

    // Each collection gets its own slider
    root.querySelectorAll('[data-stc-coll]').forEach(function (coll) {
      var track = coll.querySelector('[data-stc-track]');
      var cards = track ? track.querySelectorAll('.stc-card') : [];
      var prev = coll.querySelector('[data-stc-prev]');
      var next = coll.querySelector('[data-stc-next]');
      var currentEl = coll.querySelector('[data-stc-current]');
      var totalEl = coll.querySelector('[data-stc-total]');
      if (!track || cards.length === 0) return;
      var current = 0;

      function stepPx() {
        if (!cards.length) return 0;
        var rect = cards[0].getBoundingClientRect();
        var gap = parseFloat(getComputedStyle(track).columnGap || getComputedStyle(track).gap || '0') || 0;
        return rect.width + gap;
      }

      function perView() {
        var viewport = coll.querySelector('.stc-coll-viewport');
        if (!viewport || !cards.length) return 1;
        return Math.max(1, Math.round(viewport.clientWidth / stepPx()));
      }

      function maxIndex() { return Math.max(0, cards.length - perView()); }

      function totalPages() { return maxIndex() + 1; }

      function apply(animate) {
        var step = stepPx();
        if (animate === false) track.style.transition = 'none';
        track.style.transform = 'translateX(' + (-current * step) + 'px)';
        if (animate === false) { void track.offsetWidth; track.style.transition = ''; }
      }

      function updateNav() {
        if (prev) prev.disabled = current <= 0;
        if (next) next.disabled = current >= maxIndex();
        if (currentEl) currentEl.textContent = (current + 1);
        if (totalEl) totalEl.textContent = totalPages();
      }

      function go(i) {
        current = Math.max(0, Math.min(maxIndex(), i));
        apply(true);
        updateNav();
      }

      if (prev) prev.addEventListener('click', function () { go(current - 1); });
      if (next) next.addEventListener('click', function () { go(current + 1); });

      // Touch swipe
      var sx = 0, dx = 0, dragging = false;
      track.addEventListener('touchstart', function (e) {
        if (!e.touches || !e.touches[0]) return;
        sx = e.touches[0].clientX; dragging = true;
      }, { passive: true });
      track.addEventListener('touchmove', function (e) {
        if (!dragging || !e.touches || !e.touches[0]) return;
        dx = e.touches[0].clientX - sx;
      }, { passive: true });
      track.addEventListener('touchend', function () {
        if (!dragging) return;
        dragging = false;
        if (Math.abs(dx) > 40) { dx < 0 ? go(current + 1) : go(current - 1); }
        dx = 0;
      });

      var rt = null;
      window.addEventListener('resize', function () {
        if (rt) clearTimeout(rt);
        rt = setTimeout(function () {
          if (current > maxIndex()) current = maxIndex();
          apply(false);
          updateNav();
        }, 80);
      });

      apply(false);
      updateNav();
    });

    // ------- Modal (shared) -------
    var modal = root.querySelector('[data-stc-modal]');
    var overlay = root.querySelector('.stc-modal-overlay');
    var modalBody = root.querySelector('[data-stc-modal-body]');

    function openModal() {
      modal.classList.add('is-open');
      overlay.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function closeModal() {
      modal.classList.remove('is-open');
      overlay.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
    root.querySelectorAll('[data-stc-modal-close]').forEach(function (el) { el.addEventListener('click', closeModal); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal(); });

    function getProductData(handle) {
      var node = root.querySelector('script[data-stc-product="' + handle + '"]');
      if (!node) return null;
      try { return JSON.parse(node.textContent); } catch (e) { return null; }
    }

    root.querySelectorAll('[data-stc-quickview]').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault(); e.stopPropagation();
        var p = getProductData(btn.getAttribute('data-stc-quickview'));
        if (!p) return;
        modalBody.innerHTML = renderQuickView(p);
        openModal();
        bindQuickView(p);
      });
    });

    function renderQuickView(p) {
      var images = (p.images && p.images.length) ? p.images : (p.featured_image ? [p.featured_image] : []);
      var imagesHtml = images.map(function (src, i) {
        var url = (typeof src === 'string') ? src : (src.src || '');
        var display = url.indexOf('?') > -1 ? url.replace(/width=\d+/, 'width=800') : url + '?width=800';
        return '<div class="stc-mslide"><img src="' + display + '" alt="' + (p.title || '') + ' ' + (i+1) + '"></div>';
      }).join('');

      var priceHtml = formatMoney(p.price);
      var compareHtml = '';
      if (p.compare_at_price && p.compare_at_price > p.price) {
        compareHtml = '<span class="stc-modal-price-compare">' + formatMoney(p.compare_at_price) + '</span>';
      }

      var options = p.options || [];
      var optionsHtml = '';
      options.forEach(function (opt, oi) {
        var optName = (typeof opt === 'string') ? opt : opt.name;
        if (options.length === 1 && optName === 'Title') {
          var v0 = p.variants && p.variants[0];
          if (v0 && v0.title === 'Default Title') return;
        }
        var values = [];
        (p.variants || []).forEach(function (v) {
          var val = v.options ? v.options[oi] : v['option' + (oi + 1)];
          if (val && values.indexOf(val) === -1) values.push(val);
        });
        optionsHtml += '<div class="stc-modal-opt"><p class="stc-modal-opt-label">' + optName + ': <span data-stc-opt-val="' + oi + '">' + (values[0] || '') + '</span></p><div class="stc-modal-opt-list" data-stc-opt-list="' + oi + '">';
        values.forEach(function (val, vi) {
          optionsHtml += '<button type="button" class="stc-modal-opt-btn' + (vi === 0 ? ' is-active' : '') + '" data-stc-opt="' + oi + '" data-stc-val="' + val + '">' + val + '</button>';
        });
        optionsHtml += '</div></div>';
      });

      var descHtml = p.description ? '<div class="stc-modal-desc">' + p.description + '</div>' : '';

      return ''
        + '<div class="stc-mslider" data-stc-mslider>'
        +   '<div class="stc-mslider-viewport"><div class="stc-mslider-track" data-stc-mtrack>' + imagesHtml + '</div></div>'
        +   (images.length > 1 ? ''
            + '<div class="stc-mslider-nav">'
            +   '<button type="button" class="stc-mslider-btn" data-stc-mprev aria-label="Previous"><svg viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>'
            +   '<span class="stc-mslider-count"><span data-stc-mcurrent>1</span>/<span data-stc-mtotal>' + images.length + '</span></span>'
            +   '<button type="button" class="stc-mslider-btn" data-stc-mnext aria-label="Next"><svg viewBox="0 0 14 14" fill="none"><path d="M5 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>'
            + '</div>' : '')
        + '</div>'
        + '<h2 class="stc-modal-title">' + (p.title || '') + '</h2>'
        + '<p class="stc-modal-price">' + priceHtml + compareHtml + '</p>'
        + descHtml
        + optionsHtml
        + '<div class="stc-modal-actions">'
        +   '<div class="stc-modal-qty"><button type="button" class="stc-modal-qty-btn" data-stc-qty-minus aria-label="Decrease">-</button><input type="number" class="stc-modal-qty-input" value="1" min="1" data-stc-qty><button type="button" class="stc-modal-qty-btn" data-stc-qty-plus aria-label="Increase">+</button></div>'
        +   '<button type="button" class="stc-modal-atc" data-stc-modal-atc>Add To Cart</button>'
        + '</div>'
        + '<button type="button" class="stc-modal-buy" data-stc-modal-buy>Buy It Now</button>'
        + '<a href="' + (p.url || '#') + '" class="stc-modal-full">View Full Details <svg viewBox="0 0 14 14" fill="none" width="14" height="14"><path d="M5 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>';
    }

    function bindQuickView(p) {
      var state = {
        selected: (p.options || []).map(function (opt, oi) {
          var first = p.variants && p.variants[0];
          return first && first.options ? first.options[oi] : (first && first['option' + (oi + 1)]);
        }),
        qty: 1
      };

      function findVariant() {
        var vs = p.variants || [];
        for (var i = 0; i < vs.length; i++) {
          var v = vs[i]; var match = true;
          for (var j = 0; j < state.selected.length; j++) {
            var got = v.options ? v.options[j] : v['option' + (j + 1)];
            if (got !== state.selected[j]) { match = false; break; }
          }
          if (match) return v;
        }
        return null;
      }

      var sliderEl = modalBody.querySelector('[data-stc-mslider]');
      if (sliderEl) {
        var track = sliderEl.querySelector('[data-stc-mtrack]');
        var total = track.children.length;
        var cur = 0;
        var mprev = sliderEl.querySelector('[data-stc-mprev]');
        var mnext = sliderEl.querySelector('[data-stc-mnext]');
        var mcurEl = sliderEl.querySelector('[data-stc-mcurrent]');
        function mGo(i) {
          i = Math.max(0, Math.min(total - 1, i));
          cur = i;
          track.style.transform = 'translateX(' + (-cur * 100) + '%)';
          if (mcurEl) mcurEl.textContent = cur + 1;
          if (mprev) mprev.disabled = cur <= 0;
          if (mnext) mnext.disabled = cur >= total - 1;
        }
        if (mprev) mprev.addEventListener('click', function () { mGo(cur - 1); });
        if (mnext) mnext.addEventListener('click', function () { mGo(cur + 1); });
        mGo(0);
      }

      modalBody.querySelectorAll('.stc-modal-opt-list').forEach(function (list) {
        var oi = parseInt(list.getAttribute('data-stc-opt-list'), 10);
        list.querySelectorAll('.stc-modal-opt-btn').forEach(function (b) {
          b.addEventListener('click', function () {
            state.selected[oi] = b.getAttribute('data-stc-val');
            list.querySelectorAll('.stc-modal-opt-btn').forEach(function (x) { x.classList.remove('is-active'); });
            b.classList.add('is-active');
            var lab = modalBody.querySelector('[data-stc-opt-val="' + oi + '"]');
            if (lab) lab.textContent = state.selected[oi];
            refresh();
          });
        });
      });

      function refresh() {
        var v = findVariant();
        var priceEl = modalBody.querySelector('.stc-modal-price');
        var atc = modalBody.querySelector('[data-stc-modal-atc]');
        if (v && priceEl) {
          var cmp = (v.compare_at_price && v.compare_at_price > v.price) ? '<span class="stc-modal-price-compare">' + formatMoney(v.compare_at_price) + '</span>' : '';
          priceEl.innerHTML = formatMoney(v.price) + cmp;
        }
        if (atc) {
          if (!v || !v.available) { atc.textContent = 'Sold out'; atc.setAttribute('disabled', 'disabled'); }
          else { atc.textContent = 'Add To Cart'; atc.removeAttribute('disabled'); }
        }
      }

      var qtyInput = modalBody.querySelector('[data-stc-qty]');
      modalBody.querySelector('[data-stc-qty-minus]').addEventListener('click', function () { var n = Math.max(1, parseInt(qtyInput.value, 10) - 1); qtyInput.value = n; state.qty = n; });
      modalBody.querySelector('[data-stc-qty-plus]').addEventListener('click', function () { var n = parseInt(qtyInput.value, 10) + 1; qtyInput.value = n; state.qty = n; });
      qtyInput.addEventListener('input', function () { var n = Math.max(1, parseInt(qtyInput.value, 10) || 1); qtyInput.value = n; state.qty = n; });

      var atcBtn = modalBody.querySelector('[data-stc-modal-atc]');
      atcBtn.addEventListener('click', function () {
        var v = findVariant(); if (!v || !v.available) return;
        atcBtn.classList.add('is-loading');
        atcBtn.setAttribute('disabled', 'disabled');
        addToCart(v.id, state.qty, atcBtn)
          .then(function () { closeModal(); })
          .catch(function (err) { console.error('[sticky-collections]', err); })
          .finally(function () { atcBtn.classList.remove('is-loading'); atcBtn.removeAttribute('disabled'); });
      });

      var buyBtn = modalBody.querySelector('[data-stc-modal-buy]');
      buyBtn.addEventListener('click', function () {
        var v = findVariant(); if (!v || !v.available) return;
        buyBtn.classList.add('is-loading');
        // Buy-now: add the line, skip drawer open, then jump to /checkout.
        if (window.GlazeCart && typeof window.GlazeCart.addToCart === 'function') {
          window.GlazeCart.addToCart(v.id, { quantity: state.qty, sourceButton: buyBtn, openDrawer: false, source: 'sticky-collections:buy-now' })
            .then(function () { window.location.href = '/checkout'; })
            .catch(function (err) { console.error('[sticky-collections]', err); buyBtn.classList.remove('is-loading'); });
        } else {
          addToCart(v.id, state.qty, buyBtn)
            .then(function () { window.location.href = '/checkout'; })
            .catch(function (err) { console.error('[sticky-collections]', err); buyBtn.classList.remove('is-loading'); });
        }
      });

      refresh();
    }

    // Direct ATC from card
    root.querySelectorAll('[data-stc-atc]').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault(); e.stopPropagation();
        var id = btn.getAttribute('data-stc-atc');
        if (!id) return;
        btn.classList.add('is-loading');
        btn.setAttribute('disabled', 'disabled');
        addToCart(id, 1, btn)
          .catch(function (err) { console.error('[sticky-collections]', err); })
          .finally(function () {
            btn.classList.remove('is-loading');
            btn.removeAttribute('disabled');
          });
      });
    });

    // Thin wrapper around the universal helper in glaze-cart.js.
    function addToCart(id, quantity, sourceBtn) {
      if (window.GlazeCart && typeof window.GlazeCart.addToCart === 'function') {
        return window.GlazeCart.addToCart(id, {
          quantity: quantity,
          sourceButton: sourceBtn || null,
          source: 'sticky-collections'
        });
      }
      var url = (window.routes && window.routes.cart_add_url) || '/cart/add.js';
      return fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: parseInt(id, 10), quantity: parseInt(quantity, 10) || 1 })
      }).then(function () { window.location.href = (window.routes && window.routes.cart_url) || '/cart'; });
    }
  })();
</script>

