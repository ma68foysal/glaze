{%- liquid
  assign section_id = 'glaze-stc-' | append: section.id
-%}

{%- comment -%}
  Per-instance CSS variables. Structural styles live in assets/base.css
  under "S13. Sticky collections".
{%- endcomment -%}
<style>
  #{{ section_id }} {
    --stc-bg: {{ section.settings.bg_color }};
    --stc-fg: {{ section.settings.text_color }};
    --stc-image-radius: {{ section.settings.image_radius }}px;
    --stc-eyebrow-c: {{ section.settings.eyebrow_color }};
    --stc-eyebrow-s: {{ section.settings.eyebrow_size }}px;
    --stc-image-title-c: {{ section.settings.image_title_color }};
    --stc-image-title-s: {{ section.settings.image_title_size }}px;
    --stc-image-title-w: {{ section.settings.image_title_weight }};
    --stc-image-btn-bg: {{ section.settings.image_btn_bg }};
    --stc-image-btn-fg: {{ section.settings.image_btn_fg }};
    --stc-head-title-c: {{ section.settings.head_title_color }};
    --stc-head-title-s: {{ section.settings.head_title_size }}px;
    --stc-head-title-w: {{ section.settings.head_title_weight }};
    --stc-head-desc-c: {{ section.settings.head_desc_color }};
    --stc-head-desc-s: {{ section.settings.head_desc_size }}px;
    --stc-head-link-c: {{ section.settings.head_link_color }};
    --stc-head-link-s: {{ section.settings.head_link_size }}px;
    --stc-coll-title-c: {{ section.settings.coll_title_color }};
    --stc-coll-title-s: {{ section.settings.coll_title_size }}px;
    --stc-coll-title-w: {{ section.settings.coll_title_weight }};
    --stc-nav-bg: {{ section.settings.nav_bg }};
    --stc-nav-fg: {{ section.settings.nav_fg }};
    --stc-nav-hover-bg: {{ section.settings.nav_hover_bg }};
    --stc-nav-hover-fg: {{ section.settings.nav_hover_fg }};
    --stc-card-bg: {{ section.settings.card_bg }};
    --stc-card-radius: {{ section.settings.card_radius }}px;
    --stc-title-color: {{ section.settings.card_title_color }};
    --stc-title-size: {{ section.settings.card_title_size }}px;
    --stc-type-color: {{ section.settings.type_color }};
    --stc-type-size: {{ section.settings.type_size }}px;
    --stc-price-color: {{ section.settings.price_color }};
    --stc-price-size: {{ section.settings.price_size }}px;
    --stc-compare-color: {{ section.settings.compare_color }};
    --stc-sale-bg: {{ section.settings.sale_bg }};
    --stc-sale-fg: {{ section.settings.sale_fg }};
    --stc-new-bg: {{ section.settings.new_bg }};
    --stc-new-fg: {{ section.settings.new_fg }};
    --stc-hot-bg: {{ section.settings.hot_bg }};
    --stc-hot-fg: {{ section.settings.hot_fg }};
    --stc-badge-size: {{ section.settings.badge_size }}px;
    --stc-btn-bg: {{ section.settings.btn_bg }};
    --stc-btn-fg: {{ section.settings.btn_fg }};
    --stc-btn-hover-bg: {{ section.settings.btn_hover_bg }};
    --stc-btn-hover-fg: {{ section.settings.btn_hover_fg }};
    --stc-pad-top: {{ section.settings.padding_top }}px;
    --stc-pad-bottom: {{ section.settings.padding_bottom }}px;
    --stc-gap: {{ section.settings.coll_gap }}px;
    --stc-sticky-top: {{ section.settings.sticky_offset }}px;
  }
</style>

<div id="{{ section_id }}" class="glaze-stc" data-glaze-stc>
  <div class="stc-wrap">

    {%- if section.settings.head_title != blank or section.settings.head_desc != blank or section.settings.head_link_label != blank -%}
      <div class="stc-head" data-align="{{ section.settings.head_align }}">
        {%- if section.settings.head_title != blank -%}
          <h2 class="stc-head-title">{{ section.settings.head_title }}</h2>
        {%- endif -%}
        {%- if section.settings.head_desc != blank -%}
          <p class="stc-head-desc">{{ section.settings.head_desc }}</p>
        {%- endif -%}
        {%- if section.settings.head_link_label != blank -%}
          <a href="{{ section.settings.head_link_url | default: '#' }}" class="stc-head-link">{{ section.settings.head_link_label }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="stc-grid">

      <div class="stc-left">
        <div class="stc-image-card" data-pos="{{ section.settings.image_content_position }}">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: section.settings.image_title, widths: '400,600,800,1000,1200' }}
          {%- endif -%}
          {%- if section.settings.eyebrow != blank or section.settings.image_title != blank or section.settings.btn_label != blank -%}
            <div class="stc-image-overlay">
              {%- if section.settings.eyebrow != blank -%}
                <p class="stc-image-eyebrow">{{ section.settings.eyebrow }}</p>
              {%- endif -%}
              {%- if section.settings.image_title != blank -%}
                <h2 class="stc-image-title">{{ section.settings.image_title }}</h2>
              {%- endif -%}
              {%- if section.settings.btn_label != blank -%}
                <a href="{{ section.settings.btn_link | default: '#' }}" class="stc-image-btn">{{ section.settings.btn_label }}</a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>

      <div class="stc-right">
        {%- for block in section.blocks -%}
          {%- assign coll = block.settings.collection -%}
          {%- assign title = block.settings.title_override | default: coll.title | default: 'Collection' -%}
          {%- assign per = block.settings.products_count -%}

          <div class="stc-coll" data-stc-coll="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            <div class="stc-coll-head">
              <h3 class="stc-coll-title">{{ title }}</h3>
              <div class="stc-coll-nav">
                <button type="button" class="stc-nav-btn" data-stc-prev aria-label="Previous">
                  <svg viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <span class="stc-coll-count"><span data-stc-current>1</span>/<span data-stc-total>1</span></span>
                <button type="button" class="stc-nav-btn" data-stc-next aria-label="Next">
                  <svg viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
              </div>
            </div>

            <div class="stc-coll-viewport">
              <div class="stc-coll-track" data-stc-track>
                {%- if coll != blank -%}
                  {%- for product in coll.products limit: per -%}
                    {%- assign primary = product.featured_image -%}
                    {%- assign secondary = nil -%}
                    {%- if product.images.size > 1 -%}{%- assign secondary = product.images[1] -%}{%- endif -%}

                    {%- assign is_sale = false -%}
                    {%- if product.compare_at_price > product.price -%}
                      {%- assign is_sale = true -%}
                      {%- assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
                    {%- endif -%}
                    {%- assign is_new = false -%}
                    {%- assign is_hot = false -%}
                    {%- if product.tags contains 'new' or product.tags contains 'New' -%}{%- assign is_new = true -%}{%- endif -%}
                    {%- if product.tags contains 'hot' or product.tags contains 'Selling fast' or product.tags contains 'selling-fast' -%}{%- assign is_hot = true -%}{%- endif -%}

                    {%- assign has_variants = false -%}
                    {%- if product.variants.size > 1 or product.has_only_default_variant == false -%}{%- assign has_variants = true -%}{%- endif -%}

                    <div class="stc-card" data-product-handle="{{ product.handle }}" data-product-url="{{ product.url }}">
                      <div class="stc-card-media">
                        <a href="{{ product.url }}" class="stc-card-img is-primary" aria-label="{{ product.title }}">
                          {%- if primary -%}{{ primary | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title, widths: '300,400,600,800' }}{%- endif -%}
                        </a>
                        {%- if secondary -%}
                          <a href="{{ product.url }}" class="stc-card-img is-secondary" tabindex="-1" aria-hidden="true">
                            {{ secondary | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title, widths: '300,400,600,800' }}
                          </a>
                        {%- endif -%}

                        <div class="stc-card-badges">
                          {%- if is_sale -%}<span class="stc-badge stc-badge--sale">-{{ discount }}%</span>{%- endif -%}
                          {%- if is_new -%}<span class="stc-badge stc-badge--new">New</span>{%- endif -%}
                          {%- if is_hot -%}<span class="stc-badge stc-badge--hot">Popular</span>{%- endif -%}
                        </div>

                        <button type="button" class="stc-card-search" data-stc-quickview="{{ product.handle }}" aria-label="Quick view">
                          <svg viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"/><path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                        </button>

                        {%- if has_variants -%}
                          <button type="button" class="stc-card-cta" data-stc-quickview="{{ product.handle }}">
                            <span class="stc-card-cta-label">{{ section.settings.choose_options_label | default: 'Choose Options' }}</span>
                            <span class="stc-card-cta-icon" aria-hidden="true">
                              <svg viewBox="0 0 24 24" fill="none"><path d="M5 8h14l-1.2 11a2 2 0 0 1-2 1.8H8.2a2 2 0 0 1-2-1.8L5 8zM9 8a3 3 0 0 1 6 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </span>
                          </button>
                        {%- else -%}
                          <button type="button" class="stc-card-cta" data-stc-atc="{{ product.variants.first.id }}" {% if product.available == false %}disabled{% endif %}>
                            <span class="stc-card-cta-label">{%- if product.available -%}{{ section.settings.atc_label | default: 'Add To Cart' }}{%- else -%}Sold out{%- endif -%}</span>
                            <span class="stc-card-cta-icon" aria-hidden="true">
                              <svg viewBox="0 0 24 24" fill="none"><path d="M5 8h14l-1.2 11a2 2 0 0 1-2 1.8H8.2a2 2 0 0 1-2-1.8L5 8zM9 8a3 3 0 0 1 6 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </span>
                          </button>
                        {%- endif -%}
                      </div>

                      <a href="{{ product.url }}" class="stc-card-body" style="text-decoration:none; color:inherit;">
                        {%- if product.type != blank -%}<p class="stc-card-type">{{ product.type }}</p>{%- endif -%}
                        <p class="stc-card-title">{{ product.title }}</p>
                        <p class="stc-card-price">
                          {%- if product.price_varies -%}From {% endif -%}{{ product.price | money }}
                          {%- if is_sale -%}<span class="stc-card-price-compare">{{ product.compare_at_price | money }}</span>{%- endif -%}
                        </p>
                      </a>

                      <script type="application/json" data-stc-product="{{ product.handle }}">
                        {{ product | json }}
                      </script>
                    </div>
                  {%- endfor -%}
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>

  {%- comment -%} Shared quick-view modal {%- endcomment -%}
  <div class="stc-modal-overlay" data-stc-modal-close></div>
  <aside class="stc-modal" aria-hidden="true" role="dialog" aria-modal="true" data-stc-modal>
    <button type="button" class="stc-modal-close" data-stc-modal-close aria-label="Close">
      <svg viewBox="0 0 14 14" fill="none"><path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
    </button>
    <div class="stc-modal-inner" data-stc-modal-body></div>
  </aside>
</div>

{%- comment -%}
  Collection sliders + quick-view modal controller live in assets/global.js
  as Glaze.stickyCollections, auto-initialised on the [data-glaze-stc] root
  element above. Quick-view content is rendered by window.GlazeQuickView
  from assets/quick-view.js using the "stc" class prefix.
{%- endcomment -%}

{% schema %}
{
  "name": "Sticky collections",
  "class": "section-sticky-collections-glaze",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Section header (top)"
    },
    {
      "type": "text",
      "id": "head_title",
      "label": "Title",
      "default": "Because you need time for yourself. Blend beauty in you"
    },
    {
      "type": "color",
      "id": "head_title_color",
      "label": "Title color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "head_title_size",
      "min": 20,
      "max": 64,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 36
    },
    {
      "type": "range",
      "id": "head_title_weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "label": "Title weight",
      "default": 600
    },
    {
      "type": "textarea",
      "id": "head_desc",
      "label": "Description"
    },
    {
      "type": "color",
      "id": "head_desc_color",
      "label": "Description color",
      "default": "#444444"
    },
    {
      "type": "range",
      "id": "head_desc_size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 15
    },
    {
      "type": "text",
      "id": "head_link_label",
      "label": "Link label",
      "default": "Shop All Products"
    },
    {
      "type": "url",
      "id": "head_link_url",
      "label": "Link URL"
    },
    {
      "type": "color",
