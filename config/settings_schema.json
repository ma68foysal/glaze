[
  {
    "name": "theme_info",
    "theme_name": "Glaze",
    "theme_version": "1.0.0",
    "theme_author": "Themestudio",
    "theme_documentation_url": "https://themestudio.store/pages/glaze",
    "theme_support_url": "https://themestudio.store/pages/contact"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "assistant_n7",
        "label": "t:general.heading_font"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "dm_sans_n4",
        "label": "t:general.body_font"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "range",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "min": 1240,
        "max": 1660,
        "step": 20,
        "unit": "px",
        "default": 1440,
        "info": "t:labels.page_width_info"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "label": "t:labels.page_margin",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "default": 0,
        "info": "t:labels.page_margin_info"
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "header",
        "content": "t:general.page_colors"
      },
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#1A1A1A",
        "label": "t:labels.foreground"
      },
      {
        "type": "header",
        "content": "t:general.secondary_colors"
      },
      {
        "type": "color",
        "id": "secondary_background",
        "default": "#FBE9E8",
        "label": "t:labels.secondary_background",
        "info": "t:labels.secondary_background_info"
      },
      {
        "type": "color",
        "id": "secondary_foreground",
        "default": "#1A1A1A",
        "label": "t:labels.secondary_foreground"
      },
      {
        "type": "header",
        "content": "t:general.accent_colors"
      },
      {
        "type": "color",
        "id": "accent_background",
        "default": "#111111",
        "label": "t:labels.accent_background",
        "info": "t:labels.accent_background_info"
      },
      {
        "type": "color",
        "id": "accent_foreground",
        "default": "#FFFFFF",
        "label": "t:labels.accent_foreground"
      },
      {
        "type": "header",
        "content": "t:general.card_colors"
      },
      {
        "type": "color",
        "id": "card_background",
        "default": "#FFFFFF",
        "label": "t:labels.card_background"
      },
      {
        "type": "color",
        "id": "card_foreground",
        "default": "#1A1A1A",
        "label": "t:labels.card_foreground"
      },
      {
        "type": "header",
        "content": "t:general.form_settings"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  },
  {
    "name": "t:general.favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:labels.favicon",
        "info": "t:labels.favicon_info"
      }
    ]
  },
  {
    "name": "t:general.motion",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_smooth_scroll",
        "label": "t:labels.enable_smooth_scroll",
        "info": "t:labels.enable_smooth_scroll_info",
        "default": true
      }
    ]
  },
  {
    "name": "t:general.social",
    "settings": [
      {
        "type": "image_picker",
        "id": "share_image",
        "label": "t:labels.share_image",
        "info": "t:labels.share_image_info"
      }
    ]
  },
  {
    "name": "t:general.cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "t:labels.cart_type",
        "options": [
          { "value": "page",   "label": "t:options.cart_type.page" },
          { "value": "drawer", "label": "t:options.cart_type.drawer" }
        ],
        "default": "page",
        "info": "t:labels.cart_type_info"
      },
      {
        "type": "checkbox",
        "id": "show_cart_note",
        "label": "t:labels.show_cart_note",
        "default": true
      }
    ]
  }
]
