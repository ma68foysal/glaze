{%- comment -%}
  Localization form — country + language selector.

  Renders one `{% form 'localization' %}` with native <select>s that POST on
  change. Returns nothing on single-country, single-language stores so the
  default storefront stays clean.

  Optional inputs:
    class_prefix — root class for CSS scoping (default: 'glaze-localization').
{%- endcomment -%}

{%- assign cp = class_prefix | default: 'glaze-localization' -%}

{%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
  <div class="{{ cp }}">
    {%- form 'localization', class: cp | append: '__form' -%}
      {%- if localization.available_countries.size > 1 -%}
        <div class="{{ cp }}__field">
          <label for="{{ cp }}-country" class="visually-hidden">{{ 'general.country_label' | t }}</label>
          <select
            id="{{ cp }}-country"
            name="country_code"
            class="{{ cp }}__select"
            aria-label="{{ 'general.country_label' | t }}"
            onchange="this.form.submit()"
          >
            {%- for country in localization.available_countries -%}
              <option
                value="{{ country.iso_code }}"
                {%- if country.iso_code == localization.country.iso_code %} selected{% endif -%}
              >
                {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
              </option>
            {%- endfor -%}
          </select>
        </div>
      {%- endif -%}

      {%- if localization.available_languages.size > 1 -%}
        <div class="{{ cp }}__field">
          <label for="{{ cp }}-locale" class="visually-hidden">{{ 'general.language_label' | t }}</label>
          <select
            id="{{ cp }}-locale"
            name="locale_code"
            class="{{ cp }}__select"
            aria-label="{{ 'general.language_label' | t }}"
            onchange="this.form.submit()"
          >
            {%- for lang in localization.available_languages -%}
              <option
                value="{{ lang.iso_code }}"
                lang="{{ lang.iso_code }}"
                {%- if lang.iso_code == localization.language.iso_code %} selected{% endif -%}
              >
                {{ lang.endonym_name | capitalize }}
              </option>
            {%- endfor -%}
          </select>
        </div>
      {%- endif -%}
    {%- endform -%}
  </div>
{%- endif -%}
